    {
      "id": "ed3e5cf1e8ec0fb771da51e35d8d8b8738a5859e",
      "type": "article",
      "source": "News Canada",
      "title": "4 things to test for when buying a home",
      "url": "https://www.newscanada.com/en/4-things-to-test-for-when-buying-a-home-141281",
      "issue": "March 2026",
      "categories": [
        "Safety - Personal",
        "Home & Garden"
      ],
      "keywords": [
        "lifestyle content",
        "copyright",
        "free content",
        "editorial content",
        "fresh content",
        "mat stories",
