    {
      "id": "1eec96e515a284a1c21a8e7de16aa3bdd6728a61",
      "type": "article",
      "source": "News Canada",
      "title": "Grief support matters at every stage of serious illness",
      "url": "https://www.newscanada.com/en/grief-support-matters-at-every-stage-of-serious-illness-141331",
      "issue": "March 2026",
      "categories": [
        "Family & Parenting",
        "Health Care"
