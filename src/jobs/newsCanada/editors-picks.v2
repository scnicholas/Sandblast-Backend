    {
      "id": "f8e63f9493397a3f128c02c7f607d718b6cf4083",
      "type": "article",
      "source": "News Canada",
      "title": "Make the most of your income tax refund",
      "url": "https://www.newscanada.com/en/make-the-most-of-your-income-tax-refund-141342",
      "issue": "March 2026",
      "categories": [
        "Finance - Savings & Investment"
      ],
      "keywords": [
        "lifestyle content",
        "copyright",
        "free content",
        "editorial content",
