    {
      "id": "d1901005d09926e1e595e4f495dfc22f72863ed2",
      "type": "article",
      "source": "News Canada",
      "title": "Why you should be prepared for seasonal illnesses",
      "url": "https://www.newscanada.com/en/why-you-should-be-prepared-for-seasonal-illnesses-141278",
      "issue": "February 2026",
      "categories": [
        "55+",
        "Health Care"
      ],
      "keywords": [
        "lifestyle content",
        "copyright",
        "free content",
        "editorial content",
        "fresh content",
        "mat stories",
