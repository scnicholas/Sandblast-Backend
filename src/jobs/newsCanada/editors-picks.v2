    {
      "id": "c855e5eeb036bf1d61fa223f800f3b79e35033e7",
      "type": "article",
      "source": "News Canada",
      "title": "What’s in your cold and flu toolkit this season?",
      "url": "https://www.newscanada.com/en/what-e2-80-99s-in-your-cold-and-flu-toolkit-this-season-3f-141329",
      "issue": "March 2026",
      "categories": [
        "Safety - Personal",
        "Health Care"
      ],
      "keywords": [
        "lifestyle content",
