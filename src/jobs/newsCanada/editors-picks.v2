    {
      "id": "62354d2c6634b514a6f5b11360e8495aa3bf41f3",
      "type": "article",
      "source": "News Canada",
      "title": "New ways to enjoy family movie nights this winter",
      "url": "https://www.newscanada.com/en/new-ways-to-enjoy-family-movie-nights-this-winter-141171",
      "issue": "February 2026",
      "categories": [
        "Travel & Leisure",
        "Technology & Science",
        "Family & Parenting",
        "Home & Garden"
      ],
      "keywords": [
        "lifestyle content",
        "copyright",
        "free content",
        "editorial content",
