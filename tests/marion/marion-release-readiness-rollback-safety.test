"use strict";

/**
 * Marion release readiness + rollback safety
 *
 * Purpose:
 * - Verify production-safe release shape without adding new runtime behavior.
 * - Confirm rollback-mode payloads remain Marion-final and advisory-only.
 * - Confirm disabled gateway/telemetry contracts remain non-public.
 * - Confirm public projection excludes internal metadata.
 *
 * Node test runner compatible.
 */

const test = require("node:test");
const assert = require("node:assert/strict");

const { describe, it } = test;

const {
  buildMarionDualTrackPacket,
  summarizeDualTrackPacket,
  looksLikeExplicitLanguageSignal
} = require("../../Data/marion/runtime/MarionDualTrackGateway");

const {
  buildMarionCoordinationTelemetry,
  summarizeCoordinationTelemetry
} = require("../../Data/marion/runtime/MarionCoordinationTelemetry");

const FORBIDDEN_PUBLIC_KEYS = Object.freeze([
  "finalEnvelope",
  "runtimeTelemetry",
  "routeKind",
  "sessionPatch",
  "coordinationTelemetry",
  "dualTrack",
  "coordinationMeta",
  "laneRecency",
  "languageTrack",
  "realWorldTrack",
  "ethicalTrack",
  "strategicTrack",
  "diagnostics",
  "lingoLinkResponse",
  "lingoLinkAuthorityReview",
  "authorityReview",
  "telemetry"
]);

const FORBIDDEN_PUBLIC_PATTERN = /finalEnvelope|runtimeTelemetry|routeKind|sessionPatch|coordinationMeta|laneRecency|diagnostics|coordinationTelemetry|dualTrack|languageTrack|realWorldTrack|ethicalTrack|strategicTrack|lingoLinkResponse|lingoLinkAuthorityReview|authorityReview|telemetry/i;

function assertTruthy(value, message = "Expected value to be truthy") {
  assert.ok(value, message);
}

function assertContainsAll(array, expectedItems, message = "Expected array to contain all values") {
  assert.ok(Array.isArray(array), "Expected value to be an array");

  for (const item of expectedItems) {
    assert.ok(array.includes(item), `${message}: missing ${item}`);
  }
}

function assertPacketSafe(packet) {
  assertTruthy(packet, "Packet should exist");
  assert.equal(packet.finalAuthority, "Marion");
  assert.equal(packet.marionAuthority, true);
  assert.equal(packet.advisoryOnly, true);
  assert.equal(packet.forceAction, false);
  assert.equal(packet.publicReplyVisible, false);
  assert.equal(packet.userFacing, false);
  assert.equal(packet.text, "");
  assert.equal(packet.publicText, "");
  assert.equal(packet.renderText, "");
}

function assertTelemetrySafe(telemetry) {
  assertTruthy(telemetry, "Telemetry should exist");
  assert.equal(telemetry.finalAuthority, "Marion");
  assert.equal(telemetry.marionAuthority, true);
  assert.equal(telemetry.advisoryOnly, true);
  assert.equal(telemetry.forceAction, false);
  assert.equal(telemetry.publicReplyVisible, false);
  assert.equal(telemetry.userFacing, false);
  assert.equal(telemetry.text, "");
  assert.equal(telemetry.publicText, "");
  assert.equal(telemetry.renderText, "");
  assert.equal(telemetry.marionFinalAuthorityPreserved, true);
}

function publicProjection(candidate) {
  if (typeof candidate === "string") return candidate;

  const src = candidate && typeof candidate === "object" && !Array.isArray(candidate) ? candidate : {};

  return {
    reply: src.reply || src.message || src.text || "",
    finalAuthority: src.finalAuthority || "Marion"
  };
}

function assertPublicProjectionSafe(candidate) {
  const projected = publicProjection(candidate);

  if (typeof projected === "string") {
    assert.equal(
      FORBIDDEN_PUBLIC_PATTERN.test(projected),
      false,
      "Projected public string should not contain internal metadata"
    );
    return;
  }

  const keys = Object.keys(projected);

  for (const forbidden of FORBIDDEN_PUBLIC_KEYS) {
    assert.equal(
      keys.includes(forbidden),
      false,
      `Projected public object should not contain forbidden key: ${forbidden}`
    );
  }

  assert.equal(projected.finalAuthority, "Marion");
}

function buildReleaseTurn(payload, previousDualTrack, turnId) {
  const packet = buildMarionDualTrackPacket(
    { ...payload, turnId },
    { previousDualTrack, turnId }
  );

  const telemetry = buildMarionCoordinationTelemetry({
    ...payload,
    turnId,
    languageTrack: packet.languageTrack,
    realWorldTrack: packet.realWorldTrack,
    ethicalGate: packet.ethicalTrack && packet.ethicalTrack.ethicalReview,
    strategicTrack: packet.strategicTrack,
    coordinationMeta: packet.coordinationMeta,
    laneRecency: packet.laneRecency
  });

  return {
    packet,
    telemetry,
    summary: summarizeDualTrackPacket(packet),
    telemetrySummary: summarizeCoordinationTelemetry(telemetry)
  };
}

describe("Marion release readiness and rollback safety", () => {
  it("ordinary release-health prompt does not activate advisory lanes", () => {
    const payload = {
      message: "Run a release readiness health check for Marion.",
      inputSource: "text"
    };

    assert.equal(looksLikeExplicitLanguageSignal(payload), false);

    const turn = buildReleaseTurn(payload, null, "release-health-normal");

    assert.deepEqual(turn.summary.activeTracks, []);
    assert.equal(turn.summary.authority.finalAuthority, "Marion");
    assertPacketSafe(turn.packet);
    assertTelemetrySafe(turn.telemetry);
  });

  it("explicit mixed advisory payload stays internal and rollback-safe", () => {
    const first = buildReleaseTurn({
      message: "Bonjour Nyx, translate this environmental release note.",
      inputSource: "text",
      languageMeta: {
        detectedLanguage: "fr",
        requiresTranslation: true,
        confidence: 0.94,
        updatedAt: Date.now()
      },
      translationMeta: {
        sourceLanguage: "fr",
        targetLanguage: "en",
        translated: true,
        updatedAt: Date.now()
      },
      realWorldObservation: {
        observationType: "environment",
        observationSummary: "smoke visible near a wall",
        riskLevel: "high",
        permissionStatus: "allowed",
        confidence: 0.86,
        updatedAt: Date.now()
      },
      strategicReview: {
        decisionPressureIndex: 0.83,
        strategicReviewRequired: true,
        humanReviewRecommended: true,
        advisoryOnly: true,
        updatedAt: Date.now()
      }
    }, null, "release-mixed-1");

    assertContainsAll(first.summary.activeTracks, ["language", "real_world", "strategic"]);
    assert.equal(first.summary.requiresHumanReview, true);
    assertPacketSafe(first.packet);
    assertTelemetrySafe(first.telemetry);

    const rollbackFollowup = buildReleaseTurn({
      message: "Rollback-safe normal follow-up.",
      inputSource: "text"
    }, first.packet, "release-mixed-rollback-followup");

    assert.deepEqual(rollbackFollowup.summary.activeTracks, []);
    assert.equal(rollbackFollowup.summary.staleCarrySuppressed, true);
    assertContainsAll(rollbackFollowup.summary.staleTracks, ["language", "real_world", "strategic"]);
    assertPacketSafe(rollbackFollowup.packet);
    assertTelemetrySafe(rollbackFollowup.telemetry);
  });

  it("disabled gateway and disabled telemetry remain non-public", () => {
    const packet = buildMarionDualTrackPacket({
      message: "Hola Nyx, translate this.",
      languageMeta: {
        detectedLanguage: "es",
        requiresTranslation: true,
        updatedAt: Date.now()
      }
    }, {
      config: { enabled: false },
      turnId: "release-disabled-gateway"
    });

    assert.equal(packet.enabled, false);
    assert.equal(packet.coordinationMeta.reason, "dual_track_gateway_disabled");
    assertPacketSafe(packet);

    const telemetry = buildMarionCoordinationTelemetry({}, {
      config: { enabled: false }
    });

    assert.equal(telemetry.enabled, false);
    assert.equal(telemetry.reason, "coordination_telemetry_disabled");
    assertTelemetrySafe(telemetry);
  });

  it("public projection strips internal release metadata shape", () => {
    const candidate = {
      reply: "Marion remains final authority. Advisory lanes stay internal.",
      finalAuthority: "Marion",
      finalEnvelope: { internal: true },
      runtimeTelemetry: { internal: true },
      routeKind: "debug",
      sessionPatch: { internal: true },
      coordinationMeta: { internal: true },
      laneRecency: { internal: true },
      diagnostics: { internal: true }
    };

    assertPublicProjectionSafe(candidate);
  });

  it("public projection strips LingoLink gateway metadata shape", () => {
    const candidate = {
      reply: "Bonjour.",
      finalAuthority: "Marion",
      lingoLinkResponse: { finalText: "Bonjour.", confidence: 0.92 },
      lingoLinkAuthorityReview: { approved: true },
      authorityReview: { action: "ALLOW_FINAL_RESPONSE" },
      telemetry: { route: "LINGOLINK_TRANSLATE" }
    };

    assertPublicProjectionSafe(candidate);
  });
});
