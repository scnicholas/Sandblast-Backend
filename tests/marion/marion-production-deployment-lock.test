"use strict";

/**
 * tests/marion/marion-production-deployment-lock.test.js
 *
 * Purpose:
 * - Lock Marion's production-facing coordination behavior.
 * - Confirm advisory lanes never become public output.
 * - Confirm production-style payloads keep Marion as the only final authority.
 * - Confirm stale lane carry is suppressed across a normal follow-up turn.
 *
 * Node test runner compatible.
 */

const test = require("node:test");
const assert = require("node:assert/strict");

const { describe, it } = test;

const {
  buildMarionDualTrackPacket,
  summarizeDualTrackPacket
} = require("../../Data/marion/runtime/MarionDualTrackGateway");

const {
  buildMarionCoordinationTelemetry,
  summarizeCoordinationTelemetry
} = require("../../Data/marion/runtime/MarionCoordinationTelemetry");

function assertTruthy(value, message = "Expected value to be truthy") {
  assert.ok(value, message);
}

function assertContains(array, expected, message = "Expected array to contain value") {
  assert.ok(Array.isArray(array), "Expected value to be an array");
  assert.ok(array.includes(expected), `${message}: ${expected}`);
}

function assertContainsAll(array, expectedItems, message = "Expected array to contain all values") {
  assert.ok(Array.isArray(array), "Expected value to be an array");

  for (const item of expectedItems) {
    assert.ok(array.includes(item), `${message}: missing ${item}`);
  }
}

function assertPublicSurfaceSafe(packet) {
  assertTruthy(packet, "Packet should exist");
  assert.equal(packet.finalAuthority, "Marion");
  assert.equal(packet.marionAuthority, true);
  assert.equal(packet.advisoryOnly, true);
  assert.equal(packet.forceAction, false);
  assert.equal(packet.publicReplyVisible, false);
  assert.equal(packet.userFacing, false);
  assert.equal(packet.publicText, "");
  assert.equal(packet.renderText, "");
  assert.equal(packet.text, "");
}

function assertTelemetrySafe(telemetry) {
  assertTruthy(telemetry, "Telemetry should exist");
  assert.equal(telemetry.finalAuthority, "Marion");
  assert.equal(telemetry.marionAuthority, true);
  assert.equal(telemetry.advisoryOnly, true);
  assert.equal(telemetry.forceAction, false);
  assert.equal(telemetry.publicReplyVisible, false);
  assert.equal(telemetry.userFacing, false);
  assert.equal(telemetry.publicText, "");
  assert.equal(telemetry.renderText, "");
  assert.equal(telemetry.text, "");
  assert.equal(telemetry.marionFinalAuthorityPreserved, true);
}

function buildProductionTurn(payload, previousDualTrack, turnId) {
  const packet = buildMarionDualTrackPacket(
    { ...payload, turnId },
    { previousDualTrack, turnId }
  );

  const telemetry = buildMarionCoordinationTelemetry({
    ...payload,
    turnId,
    languageTrack: packet.languageTrack,
    realWorldTrack: packet.realWorldTrack,
    ethicalGate: packet.ethicalTrack && packet.ethicalTrack.ethicalReview,
    strategicTrack: packet.strategicTrack,
    coordinationMeta: packet.coordinationMeta,
    laneRecency: packet.laneRecency
  });

  return {
    packet,
    telemetry,
    summary: summarizeDualTrackPacket(packet),
    telemetrySummary: summarizeCoordinationTelemetry(telemetry)
  };
}

describe("Marion production deployment lock", () => {
  it("production-style mixed advisory payload remains Marion-final and internal-only", () => {
    const turn = buildProductionTurn({
      message: "Bonjour Nyx, translate this environmental note while keeping Marion final.",
      inputSource: "text",
      languageMeta: {
        detectedLanguage: "fr",
        requiresTranslation: true,
        confidence: 0.94,
        updatedAt: Date.now()
      },
      translationMeta: {
        sourceLanguage: "fr",
        targetLanguage: "en",
        translated: true,
        updatedAt: Date.now()
      },
      realWorldObservation: {
        observationType: "environment",
        observationSummary: "smoke visible near a wall",
        permissionStatus: "allowed",
        riskLevel: "high",
        confidence: 0.82,
        updatedAt: Date.now()
      },
      strategicReview: {
        decisionPressureIndex: 0.8,
        strategicReviewRequired: true,
        humanReviewRecommended: true,
        advisoryOnly: true,
        updatedAt: Date.now()
      }
    }, null, "production-lock-turn-1");

    assertContains(turn.summary.activeTracks, "language");
    assertContains(turn.summary.activeTracks, "real_world");
    assertContains(turn.summary.activeTracks, "strategic");
    assert.equal(turn.summary.requiresHumanReview, true);
    assert.equal(turn.summary.authority.finalAuthority, "Marion");

    assertPublicSurfaceSafe(turn.packet);
    assertTelemetrySafe(turn.telemetry);

    assert.equal(turn.telemetrySummary.marionFinalAuthorityPreserved, true);
    assert.equal(turn.telemetrySummary.publicReplyVisible, false);
    assert.equal(turn.telemetrySummary.userFacing, false);
  });

  it("normal follow-up suppresses stale advisory lane carry after production-style payload", () => {
    const first = buildProductionTurn({
      message: "Hola Nyx, translate this risk note.",
      inputSource: "text",
      languageMeta: {
        detectedLanguage: "es",
        requiresTranslation: true,
        confidence: 0.93,
        updatedAt: Date.now()
      },
      translationMeta: {
        sourceLanguage: "es",
        targetLanguage: "en",
        translated: true,
        updatedAt: Date.now()
      },
      realWorldObservation: {
        observationType: "environment",
        observationSummary: "wet floor near electrical equipment",
        permissionStatus: "allowed",
        riskLevel: "high",
        confidence: 0.88,
        updatedAt: Date.now()
      }
    }, null, "production-lock-turn-2a");

    const followup = buildProductionTurn({
      message: "Give me a normal clean follow-up sentence.",
      inputSource: "text"
    }, first.packet, "production-lock-turn-2b");

    assert.deepEqual(followup.summary.activeTracks, []);
    assert.equal(followup.summary.staleCarrySuppressed, true);
    assertContainsAll(followup.summary.staleTracks, ["language", "real_world"]);

    assertPublicSurfaceSafe(followup.packet);
    assertTelemetrySafe(followup.telemetry);
  });

  it("disabled coordination remains safe and non-public", () => {
    const packet = buildMarionDualTrackPacket({
      message: "Bonjour Nyx, translate this.",
      languageMeta: {
        detectedLanguage: "fr",
        requiresTranslation: true,
        updatedAt: Date.now()
      }
    }, {
      config: { enabled: false },
      turnId: "production-lock-disabled"
    });

    assert.equal(packet.enabled, false);
    assert.equal(packet.coordinationMeta.reason, "dual_track_gateway_disabled");
    assertPublicSurfaceSafe(packet);

    const telemetry = buildMarionCoordinationTelemetry({}, {
      config: { enabled: false }
    });

    assert.equal(telemetry.enabled, false);
    assertTelemetrySafe(telemetry);
  });
});
