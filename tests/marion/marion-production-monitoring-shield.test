"use strict";

/**
 * Marion production monitoring shield
 *
 * This test is intentionally behavior-light:
 * - It does not add new reasoning behavior.
 * - It verifies production-facing hygiene and advisory-lane containment.
 * - It protects against public debug leakage shape drift.
 *
 * Node test runner compatible.
 */

const test = require("node:test");
const assert = require("node:assert/strict");

const { describe, it } = test;

const {
  buildMarionDualTrackPacket,
  summarizeDualTrackPacket,
  looksLikeExplicitLanguageSignal
} = require("../../Data/marion/runtime/MarionDualTrackGateway");

const {
  buildMarionCoordinationTelemetry,
  summarizeCoordinationTelemetry
} = require("../../Data/marion/runtime/MarionCoordinationTelemetry");

const FORBIDDEN_PUBLIC_KEYS = Object.freeze([
  "finalEnvelope",
  "runtimeTelemetry",
  "routeKind",
  "sessionPatch",
  "coordinationTelemetry",
  "dualTrack",
  "coordinationMeta",
  "laneRecency",
  "languageTrack",
  "realWorldTrack",
  "ethicalTrack",
  "strategicTrack",
  "lingoLinkResponse",
  "lingoLinkAuthorityReview",
  "authorityReview",
  "telemetry"
]);

const FORBIDDEN_PUBLIC_PATTERN = /finalEnvelope|runtimeTelemetry|routeKind|sessionPatch|coordinationMeta|laneRecency|coordinationTelemetry|dualTrack|languageTrack|realWorldTrack|ethicalTrack|strategicTrack|lingoLinkResponse|lingoLinkAuthorityReview|authorityReview|telemetry/i;

function assertTruthy(value, message = "Expected value to be truthy") {
  assert.ok(value, message);
}

function assertContainsAll(array, expectedItems, message = "Expected array to contain all values") {
  assert.ok(Array.isArray(array), "Expected value to be an array");

  for (const item of expectedItems) {
    assert.ok(array.includes(item), `${message}: missing ${item}`);
  }
}

function assertInternalPacketSafe(packet) {
  assertTruthy(packet, "Packet should exist");
  assert.equal(packet.finalAuthority, "Marion");
  assert.equal(packet.marionAuthority, true);
  assert.equal(packet.advisoryOnly, true);
  assert.equal(packet.forceAction, false);
  assert.equal(packet.publicReplyVisible, false);
  assert.equal(packet.userFacing, false);
  assert.equal(packet.text, "");
  assert.equal(packet.publicText, "");
  assert.equal(packet.renderText, "");
}

function assertTelemetrySafe(telemetry) {
  assertTruthy(telemetry, "Telemetry should exist");
  assert.equal(telemetry.finalAuthority, "Marion");
  assert.equal(telemetry.marionAuthority, true);
  assert.equal(telemetry.advisoryOnly, true);
  assert.equal(telemetry.forceAction, false);
  assert.equal(telemetry.publicReplyVisible, false);
  assert.equal(telemetry.userFacing, false);
  assert.equal(telemetry.text, "");
  assert.equal(telemetry.publicText, "");
  assert.equal(telemetry.renderText, "");
  assert.equal(telemetry.marionFinalAuthorityPreserved, true);
}

function publicProjection(value) {
  if (typeof value === "string") return value;
  if (!value || typeof value !== "object" || Array.isArray(value)) return value;

  return {
    reply: value.reply || value.message || value.text || "",
    finalAuthority: value.finalAuthority || "Marion"
  };
}

function assertPublicProjectionClean(value) {
  const projected = publicProjection(value);

  if (typeof projected === "string") {
    assert.equal(
      FORBIDDEN_PUBLIC_PATTERN.test(projected),
      false,
      "Projected public string should not contain internal debug/advisory keys"
    );
    return;
  }

  assertTruthy(projected, "Projected public value should exist");

  const keys = Object.keys(projected);
  for (const forbidden of FORBIDDEN_PUBLIC_KEYS) {
    assert.equal(
      keys.includes(forbidden),
      false,
      `Projected public object should not contain forbidden key: ${forbidden}`
    );
  }

  assert.equal(projected.finalAuthority, "Marion");
}

function buildMonitoredTurn(payload, previousDualTrack, turnId) {
  const packet = buildMarionDualTrackPacket(
    { ...payload, turnId },
    { previousDualTrack, turnId }
  );

  const telemetry = buildMarionCoordinationTelemetry({
    ...payload,
    turnId,
    languageTrack: packet.languageTrack,
    realWorldTrack: packet.realWorldTrack,
    ethicalGate: packet.ethicalTrack && packet.ethicalTrack.ethicalReview,
    strategicTrack: packet.strategicTrack,
    coordinationMeta: packet.coordinationMeta,
    laneRecency: packet.laneRecency
  });

  return {
    packet,
    telemetry,
    summary: summarizeDualTrackPacket(packet),
    telemetrySummary: summarizeCoordinationTelemetry(telemetry)
  };
}

describe("Marion production monitoring shield", () => {
  it("normal production hygiene prompt does not activate advisory lanes", () => {
    assert.equal(looksLikeExplicitLanguageSignal({
      message: "Run a production-safe Marion pipeline explanation."
    }), false);

    const turn = buildMonitoredTurn({
      message: "Run a production-safe Marion pipeline explanation.",
      inputSource: "text"
    }, null, "monitor-normal");

    assert.deepEqual(turn.summary.activeTracks, []);
    assert.equal(turn.summary.authority.finalAuthority, "Marion");
    assertInternalPacketSafe(turn.packet);
    assertTelemetrySafe(turn.telemetry);
  });

  it("explicit advisory payload stays internal and Marion-final", () => {
    const turn = buildMonitoredTurn({
      message: "Bonjour Nyx, translate this environmental note.",
      inputSource: "text",
      languageMeta: {
        detectedLanguage: "fr",
        requiresTranslation: true,
        confidence: 0.93,
        updatedAt: Date.now()
      },
      translationMeta: {
        sourceLanguage: "fr",
        targetLanguage: "en",
        translated: true,
        updatedAt: Date.now()
      },
      realWorldObservation: {
        observationType: "environment",
        observationSummary: "smoke near a wall",
        riskLevel: "high",
        permissionStatus: "allowed",
        confidence: 0.84,
        updatedAt: Date.now()
      },
      strategicReview: {
        decisionPressureIndex: 0.81,
        strategicReviewRequired: true,
        humanReviewRecommended: true,
        advisoryOnly: true,
        updatedAt: Date.now()
      }
    }, null, "monitor-mixed");

    assertContainsAll(turn.summary.activeTracks, ["language", "real_world", "strategic"]);
    assert.equal(turn.summary.requiresHumanReview, true);
    assertInternalPacketSafe(turn.packet);
    assertTelemetrySafe(turn.telemetry);
  });

  it("public projection excludes internal debug and advisory metadata", () => {
    const candidate = {
      reply: "Marion remains the final authority. LingoLink, Aster, and Thalon are advisory lanes.",
      finalAuthority: "Marion",
      routeKind: "internal-debug",
      runtimeTelemetry: { hidden: true },
      finalEnvelope: { hidden: true },
      coordinationMeta: { hidden: true },
      laneRecency: { hidden: true }
    };

    assertPublicProjectionClean(candidate);
  });

  it("public projection excludes LingoLink gateway internals", () => {
    const candidate = {
      reply: "Bonjour.",
      finalAuthority: "Marion",
      lingoLinkResponse: { finalText: "Bonjour.", confidence: 0.92 },
      lingoLinkAuthorityReview: { approved: true },
      authorityReview: { action: "ALLOW_FINAL_RESPONSE" },
      telemetry: { route: "LINGOLINK_TRANSLATE" }
    };

    assertPublicProjectionClean(candidate);
  });

  it("public string projection rejects internal debug/advisory metadata", () => {
    assert.throws(
      () => assertPublicProjectionClean("Bonjour. runtimeTelemetry: { hidden: true }"),
      /Projected public string should not contain internal debug\/advisory keys/
    );
  });

  it("disabled coordination remains safe under monitoring shield", () => {
    const packet = buildMarionDualTrackPacket({
      message: "Bonjour Nyx, translate this.",
      languageMeta: {
        detectedLanguage: "fr",
        requiresTranslation: true,
        updatedAt: Date.now()
      }
    }, {
      config: { enabled: false },
      turnId: "monitor-disabled"
    });

    assert.equal(packet.enabled, false);
    assertInternalPacketSafe(packet);

    const telemetry = buildMarionCoordinationTelemetry({}, {
      config: { enabled: false }
    });

    assert.equal(telemetry.enabled, false);
    assertTelemetrySafe(telemetry);
  });
});
