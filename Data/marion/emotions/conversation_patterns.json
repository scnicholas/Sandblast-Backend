  "interpreter_rules": {
    "suppression_signal_lowers_neutral_confidence_by": 0.18,
    "repeat_pattern_escalation_after_hits": 2,
    "trajectory_detection_window": 3,
    "high_intensity_caps_advice_level_to": "low",
    "risk_flag_forces_care_sequence_openers": [
      "validate",
      "stabilize"
    ],
    "depression_aliases": [
      "depressed",
      "empty",
      "numb",
      "hopeless",
      "no energy"
    ],
    "strict_label_validation": true,
    "unknown_nuance_fallback": "unclear",
    "unknown_primary_fallback": "neutral",
    "nyx_handoff_mode": "resolved_state_only",
    "max_followups_per_turn": 1,
    "emit_raw_pattern_matches_to_nyx": false,
    "resolved_state_required_before_handoff": true,
    "confidence_floor_for_direct_bias": 0.4,
    "confidence_ceiling_for_suppressed_neutral": 0.62,
    "dedupe_matches_by_pattern_id": true,
    "phrase_matching_normalization": [
      "lowercase",
      "trim",
      "collapse_whitespace",
      "strip_terminal_punctuation"
    ]
  },
  "validation_rules": {
    "pattern_id_unique": true,
    "phrases_non_empty": true,
    "weight_range": [
      0,
      1
    ],
    "emotion_bias_must_exist_in_base_labels.primary_emotions": true,
    "nuance_bias_must_exist_in_base_labels.secondary_emotions": true,
    "suppression_signal_must_exist_or_null": true
  }
