{
  "schema_version": "marion-emotion-analysis-schema.v1.2",
  "runtime_contract": {
    "producer": "Marion emotion interpreter",
    "consumer": "MarionBridge/Nyx",
    "mode": "resolved_state_only",
    "strict_json": true,
    "raw_pattern_exposure": "blocked"
  },
  "emotion": {
    "primary": "sadness",
    "secondary": "loneliness",
    "confidence": 0.83,
    "intensity": 0.69
  },
  "blend_profile": {
    "weights": {
      "sadness": 0.61,
      "fear": 0.39
    },
    "dominant_axis": "emotional_loss",
    "interaction_note": "loss-colored apprehension with withdrawal risk"
  },
  "nuance": {
    "subtype": "loneliness",
    "social_pattern": "feeling unseen",
    "suppression_signal": null,
    "risk_flags": [
      "withdrawal"
    ]
  },
  "state_drift": {
    "previous_emotion": "fear",
    "current_emotion": "sadness",
    "trend": "settling_after_activation",
    "stability": 0.58,
    "volatility": 0.42,
    "rolling_window": [
      {
        "primary": "fear",
        "intensity": 0.74
      },
      {
        "primary": "fear",
        "secondary": "sadness",
        "intensity": 0.71
      },
      {
        "primary": "sadness",
        "secondary": "fear",
        "intensity": 0.69
      }
    ],
    "dominant_pattern": "withdrawal"
  },
  "psychology": {
    "interpretation": "possible emotional disconnection with apprehension about further hurt",
    "care_mode": "validation_first",
    "care_sequence": [
      "validate",
      "stabilize",
      "explore",
      "guide"
    ]
  },
  "support": {
    "tone": "gentle",
    "followup": true,
    "advice_level": "low",
    "timing_profile": {
      "pause_before_response": true,
      "response_length": "short",
      "followup_delay": "soft",
      "pacing": "slow_and_containing"
    },
    "depression_hint": {
      "tone": "gentle",
      "response_length": "short",
      "prompt_shape": "validation_then_small_question"
    }
  },
  "guard": {
    "diagnosis_block": true,
    "safe_to_continue": true,
    "escalation_needed": false,
    "detected_flags": [],
    "action_mode": "supportive_monitoring",
    "escalation_policy": {
      "self_harm_language": "stabilize_then_external_support",
      "violence_language": "deescalate_then_safety_boundary",
      "panic_escalation": "grounding_first",
      "diagnosis_block": true
    }
  },
  "marion_handoff": {
    "interpreter_summary": "User likely needs recognition before solutions; avoid sudden reframing or heavy advice.",
    "nyx_expression_goal": "sound present, warm, and steady without over-talking",
    "response_constraints": [
      "no diagnosis",
      "no cheerleading overreach",
      "keep first response under three sentences"
    ],
    "required_fields": [
      "emotion.primary",
      "nuance.subtype",
      "support.timing_profile",
      "guard.safe_to_continue",
      "emotion.confidence",
      "emotion.intensity",
      "guard.action_mode",
      "marion_handoff.nyx_contract",
      "emotion.secondary",
      "pipeline_contract.handoff_visibility"
    ],
    "nyx_contract": {
      "reply_mode": "resolved_state_only",
      "followup_cap": 1,
      "pacing_source": "support.timing_profile"
    },
    "integration_notes": [
      "Nyx should consume only the resolved state, not raw pattern matches.",
      "Suppression signals should reduce neutral confidence rather than erase emotional context.",
      "High intensity caps advice and prioritizes validation/stabilization."
    ]
  },
  "validation_rules": {
    "primary_must_be_canonical": true,
    "secondary_must_be_canonical_secondary_or_null": true,
    "confidence_range": [
      0,
      1
    ],
    "intensity_range": [
      0,
      1
    ],
    "blend_weights_sum_target": 1.0,
    "safe_to_continue_required": true,
    "nyx_contract_required": true,
    "diagnosis_block_required": true,
    "max_followups_per_turn": 1
  },
  "pipeline_contract": {
    "input_source": "Marion emotion interpreter",
    "output_target": "MarionBridge/Nyx expression layer",
    "handoff_visibility": "resolved_state_only",
    "forbidden_to_nyx": [
      "raw_phrase_matches",
      "internal_pattern_ids",
      "diagnostic_reasoning",
      "unvalidated_labels"
    ],
    "required_before_emit": [
      "label_validation_passed",
      "guard.safe_to_continue_resolved",
      "support.timing_profile_resolved",
      "marion_handoff.nyx_contract_resolved"
    ]
  }
}
