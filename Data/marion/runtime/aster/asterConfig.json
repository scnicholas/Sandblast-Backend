{
  "version": "0.1.1",
  "enabled": true,
  "gateway": {
    "name": "Aster",
    "role": "environmental-observation-layer",
    "status": "staged-hardened",
    "linkedGateways": [
      "LingoLink",
      "LanguageSphere"
    ],
    "description": "Aster observes environmental signals, normalizes sensor input, classifies environmental context, tags risk, and passes structured observation metadata forward without authorizing final public answers."
  },
  "authority": {
    "finalAnswerAuthorized": false,
    "marionAuthorityRequired": true,
    "publicAgent": "nyx",
    "displayAuthority": "nyx",
    "neverOverrideMarionFinal": true,
    "neverExposeInternalDiagnosticsToUser": true,
    "observationOnly": true,
    "advisoryOnly": true,
    "publicReplyVisible": false,
    "userFacing": false
  },
  "runtime": {
    "failClosed": true,
    "returnSafeEnvelopeOnError": true,
    "allowPartialObservation": true,
    "attachAsterMetadata": true,
    "attachGatewayLinkage": true,
    "defaultSource": "manual",
    "defaultSensorType": "unknown",
    "timestampRequired": false,
    "maxObservationAgeMs": 900000
  },
  "supportedSensors": {
    "weather": {
      "enabled": true,
      "readings": [
        "temperatureC",
        "humidityPercent",
        "airQualityIndex",
        "windKph",
        "pressureHpa",
        "precipitationMm",
        "uvIndex"
      ]
    },
    "airQuality": {
      "enabled": true,
      "readings": [
        "airQualityIndex",
        "pm25",
        "pm10",
        "co2Ppm",
        "vocIndex"
      ]
    },
    "indoorEnvironment": {
      "enabled": true,
      "readings": [
        "temperatureC",
        "humidityPercent",
        "co2Ppm",
        "noiseDb",
        "lightLux"
      ]
    },
    "locationContext": {
      "enabled": false,
      "readings": [
        "zone",
        "region",
        "indoorOutdoor"
      ],
      "notes": "Keep disabled until privacy boundaries and precise-location policy are finalized."
    }
  },
  "normalization": {
    "enabled": true,
    "units": {
      "temperature": "celsius",
      "wind": "kph",
      "pressure": "hpa",
      "precipitation": "mm"
    },
    "numericCoercion": true,
    "clampValues": true,
    "preserveRawReadings": true,
    "invalidReadingBehavior": "mark-invalid-and-continue",
    "ranges": {
      "temperatureC": {
        "min": -60,
        "max": 60
      },
      "humidityPercent": {
        "min": 0,
        "max": 100
      },
      "airQualityIndex": {
        "min": 0,
        "max": 500
      },
      "windKph": {
        "min": 0,
        "max": 300
      },
      "pressureHpa": {
        "min": 800,
        "max": 1100
      },
      "precipitationMm": {
        "min": 0,
        "max": 500
      },
      "uvIndex": {
        "min": 0,
        "max": 15
      },
      "pm25": {
        "min": 0,
        "max": 1000
      },
      "pm10": {
        "min": 0,
        "max": 2000
      },
      "co2Ppm": {
        "min": 250,
        "max": 10000
      },
      "vocIndex": {
        "min": 0,
        "max": 500
      },
      "noiseDb": {
        "min": 0,
        "max": 160
      },
      "lightLux": {
        "min": 0,
        "max": 200000
      }
    }
  },
  "classification": {
    "enabled": true,
    "defaultContext": "environment.general",
    "unknownContext": "environment.unknown",
    "contextMap": {
      "weather": "environment.weather.general",
      "airQuality": "environment.air-quality.general",
      "indoorEnvironment": "environment.indoor.general",
      "locationContext": "environment.location.general"
    },
    "keywords": {
      "environment.weather.heat": [
        "temperatureC",
        "humidityPercent",
        "uvIndex"
      ],
      "environment.weather.wind": [
        "windKph"
      ],
      "environment.air-quality.general": [
        "airQualityIndex",
        "pm25",
        "pm10",
        "co2Ppm",
        "vocIndex"
      ],
      "environment.indoor.comfort": [
        "temperatureC",
        "humidityPercent",
        "noiseDb",
        "lightLux"
      ]
    }
  },
  "riskTagging": {
    "enabled": true,
    "publicAlarmDefault": false,
    "riskLevels": [
      "none",
      "low",
      "moderate",
      "elevated",
      "high",
      "unknown",
      "critical"
    ],
    "defaultRiskLevel": "unknown",
    "includeReasonCodes": true,
    "thresholds": {
      "temperatureC": {
        "low": 27,
        "moderate": 32,
        "elevated": 36,
        "high": 40
      },
      "humidityPercent": {
        "low": 65,
        "moderate": 75,
        "elevated": 85,
        "high": 95
      },
      "airQualityIndex": {
        "low": 51,
        "moderate": 101,
        "elevated": 151,
        "high": 201
      },
      "windKph": {
        "low": 25,
        "moderate": 40,
        "elevated": 60,
        "high": 90
      },
      "uvIndex": {
        "low": 3,
        "moderate": 6,
        "elevated": 8,
        "high": 11
      },
      "co2Ppm": {
        "low": 800,
        "moderate": 1200,
        "elevated": 2000,
        "high": 5000
      },
      "noiseDb": {
        "low": 55,
        "moderate": 70,
        "elevated": 85,
        "high": 100
      },
      "pm25": {
        "low": 12,
        "moderate": 35,
        "elevated": 55,
        "high": 150
      },
      "pm10": {
        "low": 55,
        "moderate": 155,
        "elevated": 255,
        "high": 355
      },
      "vocIndex": {
        "low": 100,
        "moderate": 200,
        "elevated": 300,
        "high": 400
      },
      "critical": {}
    },
    "aliases": {
      "medium": "moderate",
      "normal": "none",
      "severe": "critical"
    }
  },
  "observationEnvelope": {
    "enabled": true,
    "schema": "nyx.marion.aster.observation/1.0",
    "includeRaw": true,
    "includeNormalized": true,
    "includeContext": true,
    "includeRisk": true,
    "includeGatewayMetadata": true,
    "includeAuthorityMetadata": true,
    "gatewayLinkage": {
      "gateway": "Aster",
      "linkedGateway": "LingoLink",
      "project": "Sandblast",
      "state": "staged-environmental-pathway"
    }
  },
  "lingoLinkBridge": {
    "enabled": true,
    "mode": "metadata-only",
    "translateObservationLabels": false,
    "translatePublicSummaryOnlyAfterMarionFinal": true,
    "preserveSensorKeys": true,
    "preserveScientificUnits": true,
    "preserveRiskTags": true,
    "notes": "Aster can pass labels and summaries toward LingoLink later, but Marion must authorize public final output first."
  },
  "telemetry": {
    "enabled": true,
    "logObservationCreated": true,
    "logNormalizationWarnings": true,
    "logContextClassification": true,
    "logRiskTags": true,
    "logAuthorityFlags": true,
    "publicSurfaceClean": true
  },
  "privacy": {
    "preciseLocationDisabled": true,
    "storeRawLocation": false,
    "storePersonalSensorHistory": false,
    "redactSensitiveFields": true,
    "sensitiveFields": [
      "latitude",
      "longitude",
      "address",
      "deviceId",
      "userId",
      "ipAddress"
    ]
  },
  "development": {
    "phase": "Aster Phase 0.5 after-conflagration cleanup",
    "nextPhase": "Aster Phase 1 smoke/regression validation after conflict cleanup",
    "notes": [
      "Keep Aster observational.",
      "Do not give Aster final-answer authority.",
      "Do not merge Aster into LingoLink translation flow yet.",
      "Use Aster as structured environmental metadata feeding Marion-authorized responses.",
      "After-conflagration cleanup hardened runtime authority fields.",
      "Aster remains observational/advisory only; Marion owns final public output."
    ]
  },
  "escalation": {
    "enabled": true,
    "lane": "real_world",
    "highRiskRequiresHumanReview": true,
    "criticalRiskRequiresHumanReview": true,
    "publicReplyVisible": false,
    "userFacing": false
  }
}
