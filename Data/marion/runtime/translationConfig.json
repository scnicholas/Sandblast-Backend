{
  "version": "0.3.4-lingolink-aster-gateway",
  "enabled": true,
  "defaultSourceLanguage": "auto",
  "defaultTargetLanguage": "en",
  "supportedLanguages": [
    "en",
    "fr",
    "es"
  ],
  "languageLabels": {
    "en": "English",
    "fr": "French",
    "es": "Spanish",
    "auto": "Auto-detect",
    "unknown": "Unknown"
  },
  "provider": {
    "active": "manualDictionary",
    "fallback": "identity",
    "allowRemoteProviders": false,
    "allowSelfHostedProviders": true,
    "endpoint": null,
    "timeoutMs": 8000,
    "maxCharactersPerRequest": 4500,
    "maxResponseBytes": 524288,
    "retry": {
      "enabled": false,
      "maxAttempts": 1,
      "backoffMs": 250
    },
    "manualDictionary": {
      "enabled": true,
      "failClosedOnMiss": true,
      "caseInsensitiveLookup": true,
      "punctuationTolerantLookup": true
    },
    "identity": {
      "enabled": true,
      "warning": "identity-provider-active"
    },
    "localLibreTranslate": {
      "enabled": false,
      "endpoint": "http://localhost:5000/translate",
      "timeoutMs": 8000,
      "maxResponseBytes": 524288,
      "allowRemoteProviders": false,
      "allowSelfHostedProviders": true
    },
    "localNmt": {
      "enabled": false,
      "endpoint": "http://localhost:7010/translate",
      "timeoutMs": 8000,
      "maxResponseBytes": 524288,
      "allowRemoteProviders": false,
      "allowSelfHostedProviders": true
    },
    "argos": {
      "enabled": false,
      "endpoint": "http://localhost:7010/translate",
      "timeoutMs": 8000
    },
    "huggingFaceLocal": {
      "enabled": false,
      "endpoint": "http://localhost:7010/translate",
      "timeoutMs": 8000
    }
  },
  "behavior": {
    "preserveFinalEnvelope": true,
    "translateFinalOnly": true,
    "allowInputNormalization": true,
    "attachTranslationMeta": true,
    "failClosedToOriginal": true,
    "protectBrandTerms": true,
    "protectDomainTerms": true,
    "preserveEmotionTone": true,
    "preserveUserIntent": true,
    "returnOriginalOnDetectionFailure": true,
    "blockUnsupportedLanguages": true,
    "cloneEnvelopeBeforeMutation": true,
    "neverTranslateAuthorityFields": true,
    "neverExposeInternalAuthorityToUser": true,
    "preserveProjectGatewayMetadata": true
  },
  "routing": {
    "inputNormalizationTarget": "en",
    "finalAnswerTranslation": true,
    "domainAwareTranslation": true,
    "emotionAwareTranslation": true,
    "supportedInputLanguages": [
      "en",
      "fr",
      "es"
    ],
    "supportedOutputLanguages": [
      "en",
      "fr",
      "es"
    ],
    "minimumDetectionConfidence": 0.55,
    "lowConfidenceBehavior": "default-to-original",
    "unsupportedLanguageBehavior": "return-original",
    "projectGatewayPrecedence": true
  },
  "datasets": {
    "preferredOrder": [
      "opus",
      "huggingface",
      "tatoeba"
    ],
    "phaseOnePairs": [
      "en-fr",
      "fr-en",
      "en-es",
      "es-en",
      "fr-es",
      "es-fr"
    ],
    "minimumValidationSegmentsPerPair": 15000,
    "storageRoot": "Data/translation/datasets",
    "enabled": false,
    "notes": "Dataset training/evaluation is reserved for later phases; Phase 1 uses manualDictionary and local/self-hosted provider boundaries."
  },
  "glossary": {
    "enabled": true,
    "protectedTermsFile": "Data/translation/glossaries/sandblast_protected_terms.json",
    "domainGlossaryRoot": "Data/translation/glossaries",
    "restoreTokensAfterProvider": true,
    "caseInsensitiveProtection": true,
    "protectUrls": true,
    "protectStandaloneAcronyms": true,
    "maxProtectedTermsPerRequest": 250
  },
  "translationMemory": {
    "enabled": false,
    "storageFile": "Data/translation/memory/translation_memory.json",
    "maxEntries": 25000,
    "maxTextCharacters": 4500,
    "ttlMs": 2592000000,
    "minConfidence": 0.5,
    "reuseExactMatches": true,
    "reuseNormalizedMatches": false,
    "contextAwareKeys": true,
    "includeProtectedTermsInKey": true,
    "includeGlossaryVersionInKey": true,
    "quarantineInvalidEntries": true,
    "atomicWrites": true,
    "notes": "Keep disabled until the full translator regression passes. Enable only after confirming no stale/wrong-language reuse."
  },
  "telemetry": {
    "enabled": true,
    "logProvider": true,
    "logLanguagePair": true,
    "logCharacterCount": true,
    "logFailures": true,
    "logProtectedTermsCount": true,
    "logEndpointType": true,
    "logMemoryHit": true,
    "logDetectionConfidence": true,
    "logFinalTextSlot": true,
    "logWarnings": true,
    "redactSourceText": true,
    "redactTranslatedText": true
  },
  "security": {
    "allowCredentialsInProviderUrl": false,
    "allowFileProtocolProvider": false,
    "allowRemoteProvidersByDefault": false,
    "allowedRemoteHosts": [],
    "allowedLocalHosts": [
      "localhost",
      "127.0.0.1",
      "::1",
      "0.0.0.0"
    ],
    "blockPrivateNetworkBypass": true
  },
  "protectedTerms": [
    "Sandblast",
    "Sandblast Channel",
    "Sandblast.channel",
    "sandblast.channel",
    "sandblastchannel.com",
    "Sandblast Radio",
    "Sandblast TV",
    "Sandblast one",
    "Synapse",
    "Nyx",
    "Marion",
    "Nyx/Marion",
    "Marion/Nyx",
    "Nexus",
    "Concierge",
    "Universal Translator",
    "LanguageSphere",
    "Canada Feed",
    "Sports Feed",
    "Finance & Economics",
    "Roku",
    "OIDMTC",
    "Ontario Creates",
    "AI",
    "Cyber",
    "Finance",
    "Law",
    "Psychology",
    "English",
    "Marion Bridge",
    "MarionBridge",
    "Final Authority",
    "State Spine",
    "StateSpine",
    "Context Passport",
    "authority gate",
    "final envelope",
    "loop hardlock"
  ],
  "regression": {
    "requiredRuntimeFiles": [
      "Data/marion/runtime/UniversalTranslatorAdapter.js",
      "Data/marion/runtime/LocalTranslationProvider.js",
      "Data/marion/runtime/TranslationGlossary.js",
      "Data/marion/runtime/LanguageDetect.js",
      "Data/marion/runtime/TranslationMemoryStore.js"
    ],
    "requiredTests": [
      "tests/universal-translator-integration.test.js"
    ],
    "expectedProviderForPhaseOne": "manualDictionary"
  },
  "projects": {
    "lingoLink": {
      "enabled": true,
      "stage": "gateway-hardening",
      "authority": "marion-final",
      "activeLanguages": [
        "en",
        "fr",
        "es"
      ],
      "preserve": [
        "intent",
        "tone",
        "glossary",
        "finalEnvelope",
        "contextPassport"
      ]
    },
    "aster": {
      "enabled": true,
      "stage": "environmental-pathway-staged",
      "authority": "marion-final",
      "activationMode": "metadata-first",
      "preserve": [
        "regionalContext",
        "environmentalSignal",
        "riskThreshold",
        "finalEnvelope",
        "contextPassport"
      ],
      "ingestion": {
        "enabled": false,
        "allowedSources": [],
        "failClosedToContextOnly": true
      }
    }
  },
  "gateways": {
    "lingoLink": {
      "surface": "languageSphere",
      "defaultTargetLanguage": "en",
      "failClosedToOriginal": true
    },
    "aster": {
      "surface": "environmentalPathway",
      "defaultState": "staged",
      "failClosedToOriginal": true,
      "noExternalIngestionByDefault": true
    }
  }
}
