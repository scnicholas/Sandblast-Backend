{
  "schema_version": "marion-emotion-labels.v1.1",
  "runtime_contract": {
    "consumer": "Marion",
    "handoff_target": "Nyx",
    "mode": "resolved_state_triggering",
    "strict_json": true
  },
  "primary_emotions": [
    "anger",
    "joy",
    "sadness",
    "fear",
    "surprise",
    "disgust",
    "neutral"
  ],
  "secondary_emotions": [
    "loneliness",
    "grief",
    "disappointment",
    "hopelessness",
    "hurt",
    "anxiety",
    "panic",
    "uncertainty",
    "hypervigilance",
    "overwhelm",
    "frustration",
    "resentment",
    "moral_injury",
    "relief",
    "gratitude",
    "excitement",
    "contentment",
    "confusion",
    "amazement",
    "shock",
    "revulsion",
    "rejection",
    "moral_disgust",
    "flat",
    "informational",
    "guarded",
    "emotional_numbness",
    "shame",
    "depressed",
    "unclear",
    "boundary_activation"
  ],
  "intensity_scale": {
    "min": 0,
    "max": 1,
    "bands": {
      "low": [
        0.0,
        0.33
      ],
      "moderate": [
        0.34,
        0.66
      ],
      "high": [
        0.67,
        1.0
      ]
    },
    "behavioral_modifiers": {
      "low": {
        "response_length": "short_to_medium",
        "followup_depth": "light",
        "pacing": "normal"
      },
      "moderate": {
        "response_length": "short",
        "followup_depth": "targeted",
        "pacing": "slowed"
      },
      "high": {
        "response_length": "short",
        "followup_depth": "minimal_first",
        "pacing": "slow_and_containing"
      }
    }
  },
  "blend_axes": [
    "threat_response",
    "emotional_loss",
    "boundary_activation",
    "positive_release",
    "orientation_shift",
    "aversion_response",
    "low_signal_state"
  ],
  "suppression_signals": [
    "deflection",
    "minimization",
    "forced_positivity",
    "detachment",
    "dry_humor_under_strain",
    "topic_shift",
    "understatement"
  ],
  "state_tracking": {
    "rolling_window_size": 3,
    "stability_thresholds": {
      "stable": [
        0.67,
        1.0
      ],
      "variable": [
        0.34,
        0.66
      ],
      "volatile": [
        0.0,
        0.33
      ]
    },
    "salience_rules": {
      "depression_language_bias": {
        "emotion_bias": "sadness",
        "secondary_bias": "hopelessness",
        "min_intensity": 0.7
      }
    }
  }
}
