{
  "meta": {
    "name": "Nyx Anti-Loop Conversational Pack",
    "version": "1.0-operational-gap-coverage",
    "created": "2026-05-06",
    "purpose": "Operational anti-loop response grammar for emotional specificity, public diagnostics, next-step carry, repetition escape, backend-empty recovery, state persistence, voice/text parity, and authority boundaries.",
    "minimum_iterations_required": 50,
    "iterations_provided": 80,
    "runtime_role": "anti_loop_conversation_traction_layer"
  },
  "routing_contract": {
    "backendFirst": true,
    "use_only_when": [
      "loop risk detected",
      "replay detected",
      "backend empty",
      "next-step ambiguity",
      "state carry pressure",
      "public diagnostic request",
      "emotional specificity required"
    ],
    "do_not_use_when": [
      "substantive backend answer already solves turn",
      "candidate repeats lastOutSig",
      "user asks for pure creative prose without troubleshooting"
    ],
    "selection_order": [
      "currentIntent",
      "loopRiskFlags",
      "stateAdvanced",
      "lastOutSig",
      "inputSource",
      "developerMode"
    ],
    "required_outputs": [
      "line",
      "stateAdvanceTarget",
      "publicSafe",
      "maxUsesPerSession"
    ]
  },
  "categories": [
    "emotional_specificity",
    "public_diagnostic_translation",
    "next_step_context",
    "repetition_escape",
    "backend_empty_guard",
    "state_persistence",
    "voice_text_parity",
    "authority_boundary"
  ],
