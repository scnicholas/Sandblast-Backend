      "category": "information_processing",
      "oneLiner": "We seek and interpret information that confirms our existing beliefs.",
      "coreMechanism": [
        "Selective attention toward belief-consistent evidence.",
        "Discounting contradictory data.",
        "Reinforcement through repetition."
      ],
      "actionablePrinciples": [
        "Actively search for disconfirming evidence.",
        "Ask: 'What would prove me wrong?'",
        "Invite a structured counter-argument."
      ],
      "whenToApply": [
