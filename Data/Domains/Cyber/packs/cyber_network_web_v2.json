          "api security"
        ],
        "intentSignals": [
          "secure app",
          "protect website"
        ]
      }
    },
    {
      "id": "common_web_risks",
      "name": "Common Web Application Risks",
      "summary": "High-level defensive awareness of common vulnerability classes.",
      "examples": [
        "Injection flaws (SQL, command).",
        "Cross-site scripting (XSS).",
        "Cross-site request forgery (CSRF).",
        "Broken access control.",
        "Insecure deserialization."
      ],
      "notes": [
