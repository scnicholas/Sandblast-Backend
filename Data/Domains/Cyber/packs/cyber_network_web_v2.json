          "firewall rules",
          "lateral movement"
        ],
        "intentSignals": [
          "architecture",
          "reduce risk",
          "design"
        ]
      }
    },
    {
      "id": "firewalls_and_gateways",
      "name": "Firewalls & Gateways",
      "summary": "Control inbound and outbound traffic based on defined policies.",
      "principles": [
        "Default-deny inbound traffic.",
        "Limit exposed ports to required services.",
        "Review firewall policies regularly.",
        "Log and alert on policy violations."
      ],
      "retrievalHints": {
        "keywords": [
          "firewall",
          "port exposure",
          "gateway",
          "ingress"
        ],
        "intentSignals": [
          "secure perimeter",
          "harden"
        ]
      }
    },
    {
      "id": "secure_web_architecture",
      "name": "Secure Web Architecture",
      "summary": "Design web applications and APIs to minimize attack surface and enforce validation.",
      "principles": [
        "Validate and sanitize all user input.",
        "Use parameterized queries to prevent injection flaws.",
        "Implement proper authentication and session management.",
        "Enforce HTTPS everywhere."
      ],
      "riskPatterns": [
        "Injection vulnerabilities.",
        "Improper session handling.",
        "Unencrypted traffic."
      ],
      "retrievalHints": {
        "keywords": [
          "web security",
          "input validation",
