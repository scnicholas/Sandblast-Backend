  "sections": [
    {
      "id": "network_segmentation",
      "name": "Network Segmentation",
      "summary": "Divide networks into logical segments to reduce lateral movement and blast radius.",
      "principles": [
        "Separate public-facing systems from internal systems.",
        "Restrict east-west traffic with policy controls.",
        "Use VLANs, firewalls, or microsegmentation for isolation.",
        "Monitor cross-segment traffic."
      ],
      "riskPatterns": [
        "Flat networks enabling rapid lateral movement.",
        "Overly permissive firewall rules.",
        "No monitoring between internal segments."
      ],
