      "name": "TLS & Data Encryption",
      "summary": "Protect data in transit using strong cryptographic protocols.",
      "principles": [
        "Enforce modern TLS versions.",
        "Disable weak cipher suites.",
        "Use certificates from trusted authorities.",
        "Rotate keys regularly."
