      "id": "ddos_resilience",
      "name": "DDoS & Availability Resilience",
      "summary": "Protect availability through redundancy and traffic management.",
      "principles": [
        "Use content delivery networks (CDNs).",
        "Implement rate limiting.",
        "Scale infrastructure horizontally.",
        "Monitor abnormal traffic spikes."
      ],
      "riskPatterns": [
