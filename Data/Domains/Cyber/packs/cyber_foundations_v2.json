        ]
      }
    },
    {
      "id": "principle_least_privilege",
      "name": "Least Privilege",
      "summary": "Grant only the minimum access needed, for the minimum time needed.",
      "useWhen": [
        "IAM design",
        "admin access",
        "service accounts",
        "RBAC reviews"
      ],
      "notes": [
        "Pair with periodic access reviews and just-in-time (JIT) access where possible."
      ],
