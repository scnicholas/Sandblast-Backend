  "severityFramework": {
    "tiers": [
      {
        "level": "low",
        "description": "Limited impact, minimal sensitive data exposure.",
        "responseGuidance": "Investigate and remediate with standard procedures."
      },
      {
        "level": "medium",
        "description": "Moderate impact or exposure risk.",
        "responseGuidance": "Escalate internally, document thoroughly, contain quickly."
      },
      {
        "level": "high",
        "description": "Significant data loss, operational outage, or regulatory exposure.",
        "responseGuidance": "Immediate escalation to leadership and legal/compliance."
      }
