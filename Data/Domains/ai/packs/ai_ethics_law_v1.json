  "case_law_references": [
    {
      "title": "State v. Loomis",
      "court": "Wisconsin Supreme Court",
      "year": 2016,
      "why_it_matters": "Foundational case for algorithmic risk assessment, due process concerns, disclosure limits, and judicial reliance on proprietary scoring systems in criminal justice."
    },
    {
      "title": "Google LLC v. Oracle America, Inc.",
      "court": "Supreme Court of the United States",
      "year": 2021,
      "why_it_matters": "Key case on software copyright and fair use, highly relevant to AI code reuse, interoperability, and training-related copyright arguments."
    },
    {
      "title": "Van Buren v. United States",
      "court": "Supreme Court of the United States",
      "year": 2021,
      "why_it_matters": "Important for computer misuse boundaries, authorized access doctrine, and the legal perimeter of data access in software-enabled systems."
    },
    {
      "title": "Thaler v. Vidal",
      "court": "U.S. Court of Appeals for the Federal Circuit",
      "year": 2022,
      "why_it_matters": "Core AI-patent case establishing that under current U.S. patent law an inventor must be a natural person, while leaving room for human AI-assisted invention."
    }
  ],
