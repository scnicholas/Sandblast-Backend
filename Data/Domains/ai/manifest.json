    "packs/ai_ethics_law_v1.json",
    "packs/ai_ai_psychology_v1.json",
    "packs/ai_ai_cybersecurity_v1.json",
    "packs/ai_ai_marketing_v1.json",
    "packs/ai_case_studies_v1.json",
    "examples/ai_dialogue_snippets_v1.json",
    "examples/ai_face_examples_v1.json"
  ],
  "routing": {
    "primaryLane": "ai",
    "secondaryLanes": [
      "law",
      "psychology",
      "cyber",
      "finance",
      "strategy",
      "english"
    ],
    "keywords": [
      "agent orchestration",
      "governance",
      "machine learning",
      "intelligent agent",
      "deep learning",
      "explainability",
      "alignment",
      "agent",
      "model inference",
      "orchestration",
      "ml",
      "cognitive intelligence",
      "tool routing",
      "retrieval augmented generation",
      "neural network",
      "planning",
      "large language model",
      "llm",
      "ai agent",
      "artificial intelligence",
      "rag",
      "multi-agent",
      "model evaluation",
      "embedding",
      "ai"
    ],
    "safetyFirst": true,
    "confidencePolicy": {
      "confidenceFloor": 0.62,
      "mixedIntentRequiresSecondaryLaneCheck": true,
      "safetyLaneOverridesGeneralLane": true,
      "lowConfidenceFallback": "general_with_domain_probe",
      "preserveFinalEnvelope": true
    }
  },
  "constraints": {
    "noInvestmentAdvice": true,
    "noLegalAdvice": true,
    "noMedicalAdvice": true,
    "defensiveCyberOnly": true,
    "privacyMinimization": true,
    "humanOversightRecommended": true,
    "sourceDisclosureWhenCurrentClaims": true
  },
  "packs": [
