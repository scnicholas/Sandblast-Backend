    "runtimeDomainKeyMatchesDomain": true
  },
  "notes": [
    "Runtime domain normalized from artificial_intelligence to ai for router/registry cohesion.",
    "All file references aligned to Data/Domains/ai actual inventory.",
    "2026-05-12 autopsy patch: added routing confidence policy, runtime guards, and expanded integrity checks."
  ],
  "runtimeGuards": {
    "mode": "ai_education_and_systems_support",
    "failClosedOnMissingRequiredPacks": true,
    "humanOversightRecommended": true,
    "privacyMinimization": true,
    "defensiveCyberOnly": true,
    "preserveFinalEnvelope": true,
    "domainIsolationRequired": true,
    "bootstrapGuardRequired": true
