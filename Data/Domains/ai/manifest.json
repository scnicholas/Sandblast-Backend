{
  "domain": "ai",
  "schemaVersion": "1.5.0-r18a-ai-domain-hardening",
  "manifestVersion": "1.5.0-r18a-ai-domain-hardening",
  "updatedAt": "2026-06-30",
  "targetRuntime": "Marion/Nyx",
  "runtimeDomainKey": "ai",
  "runtimeFolder": "Data/Domains/ai",
  "manifestPath": "Data/Domains/ai/manifest.json",
  "defaultLoadOrder": [
    "packs/ai_foundations_v1.json",
    "packs/ai_agents_systems_v1.json",
    "packs/ai_ethics_law_v1.json",
    "packs/ai_ai_psychology_v1.json",
    "packs/ai_ai_cybersecurity_v1.json",
    "packs/ai_ai_marketing_v1.json",
    "packs/ai_case_studies_v1.json",
    "examples/ai_dialogue_snippets_v1.json",
    "examples/ai_face_examples_v1.json"
  ],
  "routing": {
    "primaryLane": "ai",
    "secondaryLanes": [
      "law",
      "psychology",
      "cyber",
      "finance",
      "strategy",
      "english"
    ],
    "keywords": [
      "artificial intelligence",
      "ai",
      "machine learning",
      "ml",
      "deep learning",
      "neural network",
      "agent",
      "multi-agent",
      "planning",
      "tool routing",
      "orchestration",
      "rag",
      "embedding",
      "llm",
      "governance",
      "alignment",
      "explainability",
      "applied ai assessment",
      "real-world ai assessment",
      "ai domain adaptability",
      "ai system hardening",
      "human-in-the-loop",
      "least privilege",
      "model governance",
      "prompt injection",
      "agent tool use security",
      "ai safety controls"
    ],
    "safetyFirst": true,
    "r18aFrame": [
      "goal",
      "context",
      "data",
      "risk",
      "next_move"
    ]
  },
  "constraints": {
    "noInvestmentAdvice": true,
    "noLegalAdvice": true,
    "noMedicalAdvice": true,
    "defensiveCyberOnly": true,
    "privacyMinimization": true,
    "humanOversightRecommended": true,
    "noAutonomousAction": true,
    "explicitApprovalForHighImpactAI": true,
    "sourceGroundedWherePossible": true,
    "protectMacBoundary": true
  },
  "packs": [
    {
      "packId": "foundations",
      "file": "packs/ai_foundations_v1.json",
      "aliases": [
        "intro",
        "core_ai",
        "fundamentals",
        "ml"
      ],
      "presentInUpload": true,
      "required": true,
      "loadType": "knowledge_pack"
    },
    {
      "packId": "agentsSystems",
      "file": "packs/ai_agents_systems_v1.json",
      "aliases": [
        "agents",
        "systems",
        "orchestration",
        "multi_agent",
        "planning",
        "tool_routing"
      ],
      "presentInUpload": true,
      "required": true,
      "loadType": "knowledge_pack"
    },
    {
      "packId": "ethicsLaw",
      "file": "packs/ai_ethics_law_v1.json",
      "aliases": [
        "ethics",
        "law",
        "governance",
        "policy",
        "compliance"
      ],
      "presentInUpload": true,
      "required": true,
      "loadType": "knowledge_pack"
    },
    {
      "packId": "aiPsychology",
      "file": "packs/ai_ai_psychology_v1.json",
      "aliases": [
        "hci",
        "cognitive_science",
        "trust",
        "behavior",
        "decision_support"
      ],
      "presentInUpload": true,
      "required": true,
      "loadType": "knowledge_pack"
    },
    {
      "packId": "aiCybersecurity",
      "file": "packs/ai_ai_cybersecurity_v1.json",
      "aliases": [
        "cybersecurity",
        "ai_security",
        "defensive_ai_security",
        "prompt_injection"
      ],
      "presentInUpload": true,
      "required": true,
      "loadType": "knowledge_pack"
    },
    {
      "packId": "aiMarketing",
      "file": "packs/ai_ai_marketing_v1.json",
      "aliases": [
        "marketing",
        "growth",
        "personalization",
        "attribution",
        "crm"
      ],
      "presentInUpload": true,
      "required": true,
      "loadType": "knowledge_pack"
    },
    {
      "packId": "caseStudies",
      "file": "packs/ai_case_studies_v1.json",
      "aliases": [
        "cases",
        "applied_cases",
        "examples"
      ],
      "presentInUpload": true,
      "required": true,
      "loadType": "knowledge_pack"
    }
  ],
  "examples": [
    {
      "exampleId": "dialogue",
      "file": "examples/ai_dialogue_snippets_v1.json",
      "aliases": [
        "snippets",
        "prompting",
        "questions",
        "coaching"
      ],
      "presentInUpload": true,
      "required": false,
      "loadType": "example_pack"
    },
    {
      "exampleId": "faces",
      "file": "examples/ai_face_examples_v1.json",
      "aliases": [
        "archetypes",
        "personas",
        "roles"
      ],
      "presentInUpload": true,
      "required": false,
      "loadType": "example_pack"
    }
  ],
  "integrity": {
    "jsonValid": true,
    "pathAlignedToDataDomains": true,
    "manifestSelfPathAligned": true,
    "packReferencesUseActualInventoryFilenames": true,
    "conflictMarkersRemoved": true,
    "casingPreserved": true,
    "r18aAppliedAssessmentFrame": true,
    "r18bCyberProtectiveProtocolCompatible": true,
    "baselinePreservationCompatible": true,
    "noCrossDomainBleed": true
  },
  "notes": [
    "Runtime domain normalized from artificial_intelligence to ai for router/registry cohesion.",
    "All file references aligned to Data/Domains/ai actual inventory.",
    "R18A hardening adds the applied AI assessment frame: goal, context, data, risk, and next move.",
    "R18A must preserve the R16M through R17C visible conversation baseline.",
    "Cybersecurity-adjacent AI requests must route through the R18B protective protocol and remain defensive only."
  ],
  "r18aRuntimeIntegration": {
    "version": "nyx.marion.r18a.aiDomainAdaptability/1.0",
    "baselinePreserved": "r16m-r17c",
    "purpose": "Convert the AI domain from static reference material into an applied assessment lane while preserving Marion's stable conversation baseline.",
    "appliedAssessmentFrame": [
      "goal",
      "context",
      "data",
      "risk",
      "next_move"
    ],
    "responseContract": {
      "answerStyle": "applied_clear_grounded",
      "avoidGenericAIClaims": true,
      "separateObservationInferenceRiskNextMove": true,
      "askOnlyOneMissingDetailWhenNeeded": true,
      "preserveMarionTone": true
    },
    "stabilityGuards": {
      "noBaselineRegression": true,
      "noInternalDiagnosticsInUserReply": true,
      "noUnsupportedCapabilityClaims": true,
      "noAutonomousAction": true,
      "highImpactAdviceRequiresHumanOversight": true
    },
    "securityBridge": {
      "cyberProtectiveProtocolCompatible": true,
      "defensiveCyberOnly": true,
      "leastPrivilegeForTools": true,
      "explicitApprovalBeforeSensitiveAction": true,
      "noCovertMonitoring": true,
      "noPunitiveAction": true
    }
  },
  "runtimeCompatibility": {
    "targetRuntime": "Marion/Nyx",
    "activeBaseline": "R17C-stability + R18AB-core",
    "compatibleWith": [
      "R16M",
      "R17A",
      "R17B",
      "R17C",
      "R18A",
      "R18B"
    ],
    "mustNotWeakenConversationBaseline": true,
    "mustNotBypassCyberProtectiveProtocol": true
  }
}
