    {
      "id": "lr_noting_up",
      "title": "Noting Up and Validating Authority",
      "coreDefinition": "Noting up is the process of checking how a case or statute has been treated by subsequent decisions.",
      "frameworkSteps": [
        "Use citation tools (e.g., CanLII’s cited-by feature).",
        "Check if the decision was overturned or distinguished.",
        "Confirm the section of statute is still in force."
      ],
      "quickExamples": [
        "Look for 'overruled' or 'reversed' in citing cases.",
        "Verify statute consolidation date."
      ],
      "commonMistakes": [
        "Failing to confirm current validity.",
        "Ignoring appellate history."
      ],
