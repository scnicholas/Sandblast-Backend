    {
      "id": "lr_statutes_and_regulations",
      "title": "Finding Statutes and Regulations",
      "coreDefinition": "Statutes are enacted by legislatures (Parliament or provincial assemblies). Regulations are subordinate legislation made under statutory authority.",
      "frameworkSteps": [
        "Identify jurisdiction (federal or province/territory).",
        "Search official government websites for consolidated statutes.",
        "Check regulations linked to the statute.",
        "Confirm currency (in force date and amendments)."
      ],
      "quickExamples": [
        "Federal: laws-lois.justice.gc.ca for consolidated statutes.",
        "Ontario: e-Laws website for statutes and regulations."
      ],
      "commonMistakes": [
        "Using outdated versions.",
        "Not checking if the section has been amended."
      ],
      "retrievalHints": {
        "keywords": [
          "statute",
          "regulation",
          "act",
          "section",
          "amended",
          "finding statutes and regulations",
          "lr statutes and regulations"
        ],
