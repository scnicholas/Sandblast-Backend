    {
      "id": "lr_case_law_research",
      "title": "Case Law Research",
      "coreDefinition": "Case law consists of judicial decisions interpreting statutes or developing common law principles.",
      "frameworkSteps": [
        "Search CanLII or official court websites.",
        "Identify leading or frequently cited cases.",
        "Note the court level (Supreme Court decisions bind lower courts).",
        "Check if the case has been followed, distinguished, or overturned."
      ],
      "quickExamples": [
        "Use keyword search plus jurisdiction filter on CanLII.",
        "Review headnotes for quick overview but read key reasoning sections."
      ],
      "commonMistakes": [
        "Relying only on headnotes.",
        "Not verifying whether a case is still good law."
      ],
