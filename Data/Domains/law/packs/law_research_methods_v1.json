    {
      "id": "lr_reading_a_case",
      "title": "How to Read a Case",
      "coreDefinition": "Judicial decisions contain procedural history, facts, issues, reasoning, and a holding (ratio decidendi).",
      "frameworkSteps": [
        "Identify material facts.",
        "Determine the legal issue(s).",
        "Extract the court’s reasoning.",
        "Isolate the binding principle (ratio).",
        "Distinguish obiter dicta from binding reasoning."
      ],
      "quickExamples": [
        "Ratio: The principle necessary for the decision.",
        "Obiter: Comments not essential to the decision."
      ],
      "commonMistakes": [
        "Confusing facts with legal principles.",
        "Treating obiter dicta as binding."
      ],
      "retrievalHints": {
        "keywords": [
