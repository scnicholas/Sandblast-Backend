      "title": "Burden and Standard of Proof",
      "coreDefinition": "The burden of proof determines who must prove a claim. The standard of proof determines how convincing that proof must be.",
      "frameworkSteps": [
        "Identify which party bears the burden.",
        "Determine applicable standard (balance of probabilities or beyond a reasonable doubt).",
        "Assess whether evidence meets threshold."
      ],
      "quickExamples": [
        "Civil cases use balance of probabilities.",
        "Criminal cases require proof beyond a reasonable doubt."
      ],
      "commonMistakes": [
        "Confusing criminal and civil standards.",
        "Assuming equal evidentiary thresholds."
      ],
