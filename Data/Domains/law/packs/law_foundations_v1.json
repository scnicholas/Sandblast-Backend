      "id": "lf_jurisdiction",
      "title": "Jurisdiction (Federal vs Provincial Authority)",
      "coreDefinition": "Jurisdiction determines which level of government or court has authority over a legal matter. In Canada, powers are divided between federal and provincial governments under the Constitution Act, 1867.",
      "frameworkSteps": [
        "Identify subject matter (criminal, property, employment, contracts, immigration, etc.).",
        "Determine whether authority flows from federal or provincial legislation.",
        "Confirm which court or tribunal has subject-matter jurisdiction."
      ],
      "quickExamples": [
        "Criminal law is federal (Criminal Code).",
        "Property and civil rights are primarily provincial.",
        "Immigration is primarily federal jurisdiction."
      ],
      "commonMistakes": [
        "Assuming federal law applies to all matters.",
        "Ignoring tribunal-specific jurisdiction limits."
      ],
