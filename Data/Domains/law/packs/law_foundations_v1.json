      "id": "lf_sources_of_law",
      "title": "Sources of Law in Canada",
      "coreDefinition": "Canadian law derives from constitutional law, statutes and regulations, and case law. Secondary sources interpret but do not bind.",
      "frameworkSteps": [
        "Check constitutional provisions if rights or division of powers are involved.",
        "Locate relevant statute and regulations.",
        "Identify leading cases interpreting the statute.",
        "Consult secondary sources for context."
      ],
      "quickExamples": [
        "Charter rights questions begin with constitutional analysis.",
        "Employment disputes often begin with provincial statutes."
      ],
      "commonMistakes": [
        "Treating commentary as binding authority.",
        "Ignoring hierarchy of courts."
      ],
