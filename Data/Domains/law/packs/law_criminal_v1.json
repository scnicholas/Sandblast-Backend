      "id": "lc_strict_and_absolute_liability",
      "title": "Strict and Absolute Liability Offences",
      "coreDefinition": "Some regulatory offences do not require traditional mens rea. Strict liability allows a due diligence defence; absolute liability does not.",
      "frameworkSteps": [
        "Identify whether offence is regulatory in nature.",
        "Determine if statute specifies strict or absolute liability.",
        "Assess availability of due diligence defence."
      ],
      "quickExamples": [
        "Traffic offences are often strict liability.",
        "Absolute liability offences cannot result in imprisonment under the Charter."
      ],
      "commonMistakes": [
        "Assuming all offences require intent.",
        "Confusing strict with absolute liability."
      ],
