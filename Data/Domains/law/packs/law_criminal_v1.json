      "id": "lc_charter_in_criminal",
      "title": "Charter Rights in Criminal Proceedings",
      "coreDefinition": "The Canadian Charter of Rights and Freedoms protects individuals during investigation and prosecution, including rights to counsel, protection against unreasonable search, and trial within a reasonable time.",
      "frameworkSteps": [
        "Identify alleged Charter breach (e.g., section 8 search and seizure, section 10 right to counsel).",
        "Assess whether state action violated Charter right.",
        "Determine appropriate remedy (e.g., exclusion of evidence under section 24(2))."
      ],
      "quickExamples": [
        "Failure to inform accused of right to counsel may violate section 10(b).",
        "Unlawful search may lead to exclusion of evidence."
      ],
      "commonMistakes": [
        "Assuming all Charter breaches invalidate charges.",
        "Ignoring requirement of state action."
      ],
