    {
      "id": "lcc_constitutional_supremacy",
      "title": "Constitutional Supremacy",
      "coreDefinition": "The Constitution is the supreme law of Canada. Any law inconsistent with it is of no force or effect to the extent of the inconsistency (Constitution Act, 1982, s.52).",
      "frameworkSteps": [
        "Identify the challenged law or government action.",
        "Determine relevant constitutional provision.",
        "Assess whether inconsistency exists.",
        "Consider remedy (e.g., declaration of invalidity)."
      ],
      "quickExamples": [
        "A provincial law conflicting with Charter protections may be struck down.",
        "Federal law exceeding division-of-powers authority may be invalid."
      ],
      "commonMistakes": [
        "Assuming all unfair laws are unconstitutional.",
        "Ignoring division-of-powers analysis before Charter analysis."
      ],
