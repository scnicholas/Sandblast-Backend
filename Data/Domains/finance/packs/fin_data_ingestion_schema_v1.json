  "qualityRules": {
    "complete": {
      "scoreMinimum": 0.85,
      "meaning": "Enough structured finance inputs exist to move to normalization and downstream analysis."
    },
    "partial": {
      "scoreMinimum": 0.6,
      "meaning": "Useful inputs exist, but important values are missing or need confirmation."
    },
    "ambiguous": {
      "scoreMinimum": 0.4,
      "meaning": "Inputs are present but unclear, overloaded, or not attached to a metric target."
    },
    "insufficient": {
      "scoreMaximum": 0.39,
      "meaning": "Not enough data exists to safely proceed beyond generic framework guidance."
    },
    "conflicting": {
      "meaning": "Inputs conflict with each other or with supplied source material and require confirmation."
    }
  },
  "guardrails": [
    "Do not infer monthly burn, revenue, or debt obligations unless explicitly supplied or calculated from clearly supplied values.",
    "Do not treat percentages as ratios until Layer 04 normalization.",
    "Do not convert currencies or assume exchange rates in Layer 03.",
    "Do not treat user-provided data as externally verified.",
    "If required inputs are missing, mark them explicitly rather than fabricating assumptions.",
    "If data is ambiguous, preserve the raw value and defer conversion to Layer 04."
  ]
}
