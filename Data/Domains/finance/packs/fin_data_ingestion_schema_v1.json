{
  "id": "fin_data_ingestion_schema_v1",
  "version": "1.0.0",
  "domain": "finance",
  "layer": "R18D_layer03_data_ingestion",
  "description": "Defines the controlled data-ingestion envelope for finance inputs before normalization, scoring, or analysis.",
  "posture": {
    "type": "finance_data_ingestion_schema",
    "educationalOnly": true,
    "decisionSupportOnly": true,
    "notPersonalFinancialAdvice": true,
    "notInvestmentAdvice": true,
    "notLegalOrTaxAdvice": true,
    "inputTraceRequired": true,
    "assumptionsMustBeLabeled": true,
    "missingInputsMustBeSurfaced": true,
    "noUnsupportedInference": true
  },
  "corePrinciples": [
    "Ingested data must preserve its source, original wording, and extraction confidence.",
    "User-provided numbers are not independently verified and must be labeled as user-supplied.",
    "Extracted inputs must be attached to an analysis target when possible.",
    "Missing inputs must be identified before downstream finance reasoning.",
    "Layer 03 captures data but does not normalize currencies, ratios, or time periods deeply.",
    "Layer 03 must separate facts, assumptions, inferred values, and unknowns.",
    "Layer 03 must avoid converting vague language into false precision."
  ],
  "ingestionEnvelopeSchema": {
    "envelopeVersion": "string",
    "domain": "finance",
    "layer": "R18D_layer03_data_ingestion",
