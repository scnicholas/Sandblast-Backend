{
  "id": "fin_query_patterns_v1",
  "version": "1.0.0",
  "domain": "finance",
  "layer": "R18D_layer01_intent_classification",
  "description": "Query pattern map for detecting finance user intent, risk language, jurisdiction markers, source needs, and advisory-boundary triggers.",
  "posture": {
    "type": "query_pattern_detection",
    "educationalOnly": true,
    "decisionSupportOnly": true,
    "notPersonalFinancialAdvice": true,
    "notInvestmentAdvice": true,
    "notLegalOrTaxAdvice": true,
    "assumptionDisclosureRequired": true
  },
  "normalizationRules": [
    {
      "rule": "lowercase_input",
      "description": "Convert query to lowercase before matching pattern groups."
    },
    {
      "rule": "strip_punctuation_for_keyword_match",
      "description": "Remove punctuation for keyword matching while preserving original query for response."
    },
    {
      "rule": "preserve_numbers_currency_percentages",
      "description": "Do not strip numeric values, currency symbols, percentages, or date references."
    },
    {
      "rule": "detect_multi_intent",
      "description": "Allow more than one intent when the query includes risk, business model, compliance, and source language together."
    },
    {
      "rule": "flag_jurisdiction_terms",
      "description": "Detect country, province, state, federal, cross-border, tax, securities, and regulator terms."
    }
  ],
