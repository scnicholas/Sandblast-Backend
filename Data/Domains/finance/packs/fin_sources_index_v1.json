  "id": "fin_sources_index_v1",
  "version": "2.0.0",
  "domain": "finance",
  "layer": "finance_source_index",
  "description": "Cross-domain finance reference map for official sources, textbooks, market data, public policy sources, filings, and finance/business press. This index is used by Layer 2 source authority control as the source directory.",
  "posture": {
    "type": "source_directory",
    "educationalOnly": true,
    "decisionSupportOnly": true,
    "notPersonalFinancialAdvice": true,
    "notInvestmentAdvice": true,
    "notLegalOrTaxAdvice": true,
    "sourceTraceRequired": true,
    "authorityLayerRequired": true,
    "freshnessLayerRequiredForCurrentClaims": true
  },
  "corePrinciples": [
    "Use official sources for current policy, regulatory, tax, grant, and compliance claims.",
    "Use central banks and official statistical agencies for macroeconomic claims.",
    "Use regulatory filings for issuer-specific financial facts.",
    "Use market data and exchanges for market reference claims.",
    "Use professional and open-learning sources for conceptual finance frameworks.",
    "Use major financial press for narrative and event context, not as sole authority for compliance claims.",
    "Use user-provided inputs only as user-supplied business data unless externally verified."
  ],
