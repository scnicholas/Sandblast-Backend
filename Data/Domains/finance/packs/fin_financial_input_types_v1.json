  "ambiguousInputRules": [
    {
      "rawSignal": "margin",
      "possibleMetrics": [
        "gross_margin",
        "net_margin",
        "contribution_margin"
      ],
      "action": "preserve_as_ambiguous_metric_and_request_context_if_material"
    },
    {
      "rawSignal": "rate",
      "possibleMetrics": [
        "interest_rate",
        "churn_rate",
        "growth_rate",
        "tax_rate"
      ],
      "action": "use surrounding context_to_disambiguate_or_request_confirmation"
    },
    {
      "rawSignal": "revenue",
      "possibleMetrics": [
        "monthly_revenue",
        "annual_revenue",
        "revenue_decline"
      ],
      "action": "detect period_or_mark_period_missing"
    },
    {
      "rawSignal": "cost",
      "possibleMetrics": [
        "monthly_fixed_costs",
        "monthly_variable_costs",
        "CAC",
        "COGS"
      ],
      "action": "detect cost category_or_mark_ambiguous"
    }
  ],
  "guardrails": [
    "Do not assume monthly or annual period unless stated or strongly implied.",
    "Do not convert a percentage into a ratio in Layer 03.",
    "Do not treat a generic rate as an interest rate without context.",
    "Do not label revenue as profit.",
    "Do not label cash on hand as runway without burn-rate data.",
    "Do not infer CAC, LTV, or churn unless explicitly supplied or calculated later from sufficient inputs."
  ]
}
