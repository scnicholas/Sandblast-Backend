  "id": "fin_financial_input_types_v1",
  "version": "1.0.0",
  "domain": "finance",
  "layer": "R18D_layer03_data_ingestion",
  "description": "Catalog of finance input types that Layer 03 may detect, label, and pass forward for normalization.",
  "posture": {
    "type": "financial_input_type_catalog",
    "educationalOnly": true,
    "decisionSupportOnly": true,
    "notPersonalFinancialAdvice": true,
    "notInvestmentAdvice": true,
    "notLegalOrTaxAdvice": true,
    "rawValuePreservationRequired": true,
    "normalizationDeferredToLayer04": true
  },
  "corePrinciples": [
    "Financial inputs must be typed before they are analyzed.",
    "The same number can mean different things depending on context.",
    "Metric labels should preserve uncertainty when context is incomplete.",
    "Layer 03 should detect candidate metrics, not force final interpretation.",
    "Each input type should define expected units and common aliases."
  ],
