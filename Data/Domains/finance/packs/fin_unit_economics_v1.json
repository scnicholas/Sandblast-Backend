{
  "id": "fin_unit_economics_v1",
  "version": "2.0.0",
  "domain": "finance",
  "description": "Unit economics framework for evaluating business sustainability, scalability, and capital efficiency. Focused on contribution margin, customer acquisition cost, lifetime value, and payback dynamics.",
  "posture": {
    "type": "operational_finance_framework",
    "analytical": true,
    "not_personal_financial_advice": true,
    "scalability_oriented": true
  },
  "corePrinciples": [
    "Growth without positive unit economics compounds losses.",
    "Contribution margin must be positive before scaling.",
    "Lifetime value must exceed customer acquisition cost.",
    "Cash flow timing matters as much as profitability.",
    "Retention drives lifetime value more than pricing alone.",
    "Fixed vs variable cost structure determines operating leverage.",
    "Scaling amplifies both strengths and weaknesses."
  ],
  "coreMetrics": {
    "revenue_per_unit": {
      "definition": "Revenue generated per customer, seat, transaction, or contract.",
      "drivers": [
        "pricing_model",
        "upsells",
        "cross_sells",
        "usage_intensity"
      ]
    },
    "variable_cost_per_unit": {
      "definition": "Costs directly tied to serving one additional unit/customer.",
      "examples": [
        "hosting_costs",
        "transaction_fees",
        "support_cost_per_account",
        "payment_processing_fees"
      ]
    },
    "contribution_margin": {
      "formula": "revenue_per_unit - variable_cost_per_unit",
      "interpretation": "Cash contribution toward fixed costs and profit."
    },
    "gross_margin_percentage": {
      "formula": "(revenue - cost_of_goods_sold) / revenue",
      "diagnosticUse": "Evaluates pricing power and cost structure health."
    },
    "customer_acquisition_cost_cac": {
      "definition": "All-in cost to acquire one paying customer.",
      "components": [
        "advertising_spend",
        "sales_commissions",
        "marketing_team_costs",
        "onboarding_costs"
      ]
    },
    "lifetime_value_ltv": {
      "definition": "Expected gross profit generated by a customer over lifetime.",
      "simplifiedFormula": "average_revenue_per_period * gross_margin * average_customer_lifespan"
    },
    "payback_period": {
      "definition": "Time required to recover CAC from contribution margin.",
      "interpretation": "Shorter payback improves capital efficiency."
    }
  },
  "keyRatios": [
    {
      "name": "ltv_to_cac_ratio",
      "targetGuideline": "greater_than_3x",
      "interpretation": "Indicates sustainable growth if retention assumptions hold."
    },
    {
      "name": "cac_payback_months",
      "targetGuideline": "less_than_12_months_for_saas",
      "interpretation": "Short payback reduces financing risk."
    },
    {
      "name": "gross_margin_threshold",
      "targetGuideline": "greater_than_60_percent_for_saas",
      "interpretation": "Higher margin allows reinvestment and resilience."
    }
  ],
  "operatingLeverage": {
    "definition": "Degree to which fixed costs dominate cost structure.",
    "implications": [
      "high_operating_leverage_amplifies_profit_in_growth",
      "high_operating_leverage_amplifies_loss_in_downturn"
    ],
    "diagnostics": [
      "fixed_cost_ratio",
      "break_even_volume",
      "margin_sensitivity_to_volume"
    ]
  },
  "retentionDynamics": {
    "drivers": [
      "product_value_delivery",
      "switching_costs",
      "contract_structure",
      "customer_support_quality"
    ],
    "metrics": [
      "churn_rate",
      "net_revenue_retention",
      "cohort_retention_curve"
    ],
    "implications": [
      "small_retention_improvements_compound_ltv",
      "high_churn_destroys_scalability"
    ]
  },
  "scalingChecklist": [
    "contribution_margin_positive",
    "ltv_exceeds_cac_by_safe_margin",
    "payback_period_within_cash_tolerance",
    "support_costs_do_not_scale_linearly",
    "retention_stable_or_improving"
  ],
  "failurePatterns": [
    "high_growth_negative_margin",
    "overreliance_on_discounting",
    "hidden_variable_costs",
    "long_cac_payback_period",
    "churn_masked_by_new_customer_growth"
  ],
  "scenarioStressTesting": [
    "increase_cac_by_25_percent",
    "reduce_retention_by_10_percent",
    "lower_price_by_15_percent",
    "increase_variable_costs_by_20_percent"
  ],
  "diagnosticQuestions": [
    "What is true contribution margin per unit?",
    "How sensitive is LTV to small retention changes?",
    "What happens if CAC rises next quarter?",
    "Is growth financed by profit or capital?",
    "Where do variable costs hide?"
  ],
  "exampleUseCases": [
    "evaluating_saas_scalability",
    "analyzing_ecommerce_margin_pressure",
    "designing_pricing_to_improve_unit_economics",
    "stress_testing_subscription_model",
    "improving_retention_to_raise_ltv"
  ],
  "glossary": {
    "contribution_margin": "revenue_minus_variable_cost",
    "operating_leverage": "proportion_of_fixed_costs_in_total_cost_structure",
    "churn": "percentage_of_customers_lost_over_period",
    "net_revenue_retention": "revenue_retained_from_existing_customers_including_expansion",
    "payback_period": "time_required_to_recover_customer_acquisition_cost"
  },
