  "caseStudiesV2": [
    {
      "id": "discounting_trap",
      "scenario": "company buys volume with discounts but loses margin",
      "teaches": [
        "elasticity is not infinite",
        "reference-price damage"
      ]
    },
    {
      "id": "switching_cost_misread",
      "scenario": "team assumes sticky users but churn spikes after competitor entry",
      "teaches": [
        "switching costs must be observed, not imagined"
      ]
    },
    {
      "id": "bundle_vs_unbundle",
      "scenario": "service offer can be sold as suite or modules",
