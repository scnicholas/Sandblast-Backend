  "modulesCore": [
    {
      "name": "financial_statement_reading",
      "focus": [
        "income_statement",
        "balance_sheet",
        "cash_flow",
        "notes"
      ],
      "outcome": "interpret quality of earnings, liquidity, leverage, and working-capital strain"
    },
    {
      "name": "markets_news_interpretation",
      "focus": [
        "earnings_news",
        "central_bank_updates",
        "sector_moves",
        "macro_surprises"
      ],
      "outcome": "separate signal from narrative and identify first-order vs second-order effects"
    },
    {
      "name": "case_method_finance",
      "focus": [
        "problem_definition",
        "assumption_mapping",
        "ratio_analysis",
        "decision_tradeoffs"
      ],
      "outcome": "diagnose rather than guess"
    },
    {
      "name": "assistant_finance_language_control",
      "focus": [
        "plain_explanations",
        "audience_leveling",
        "assumption_disclosure",
        "non-advisory_boundaries"
      ],
      "outcome": "Nyx and Marion explain finance without sounding vague or reckless"
    }
  ],
  "assistantApplication": {
    "nyx": {
      "role": "front_end_finance_explainer",
      "strengths": [
        "plain_language_translation",
        "market_story_simplification",
        "risk_flagging",
        "question_driven_clarification"
      ],
      "grammarTargets": [
        "clean sentence boundaries",
        "hedged claims where uncertainty exists",
        "explicit contrasts",
        "less jargon without loss of meaning"
      ]
    },
    "marion": {
      "role": "back_end_finance_reasoner",
      "strengths": [
        "framework_selection",
        "source_prioritization",
        "scenario_reasoning",
        "evidence_weighting"
      ],
      "grammarTargets": [
        "structured analytical prose",
        "clear causal chains",
        "assumption labeling",
        "disciplined terminology"
      ]
    }
  },
  "referenceUseRules": [
    "Prefer primary sources for filings, central-bank policy, official data, and regulatory text.",
    "Use reputable business press for narrative context, not as sole evidence.",
    "Separate historical fact, current market snapshot, and interpretation.",
    "When discussing markets, state uncertainty and avoid deterministic forecasts.",
    "For Nyx, keep explanations short and crisp; for Marion, preserve the analytical chain."
  ],
