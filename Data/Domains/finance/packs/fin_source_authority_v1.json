  "authorityDecisionRules": [
    {
      "condition": "claim_is_current_policy_or_rate",
      "requiredTier": "primary_official",
      "minimumAuthorityWeight": 0.9
    },
    {
      "condition": "claim_is_regulatory_or_compliance_sensitive",
      "requiredTier": "primary_official",
      "minimumAuthorityWeight": 0.9
    },
    {
      "condition": "claim_is_company_specific_financial_fact",
      "requiredTier": "primary_filings",
      "minimumAuthorityWeight": 0.88
    },
    {
      "condition": "claim_is_market_narrative",
      "requiredTier": "major_financial_press",
      "minimumAuthorityWeight": 0.65
    },
    {
      "condition": "claim_is_user_business_modeling",
      "requiredTier": "user_provided_operational_data",
      "minimumAuthorityWeight": 0.65
    },
    {
      "condition": "source_is_unknown_or_unsourced",
      "requiredTier": "unsupported_or_unknown",
      "minimumAuthorityWeight": 0.0
    }
  ],
  "outputEnvelopeSchema": {
    "domain": "finance",
    "layer": "source_authority",
    "sourceName": "string",
    "sourceType": "string",
    "sourceTier": "string",
    "authorityWeight": "number_0_to_1",
    "citationRequired": "boolean",
    "freshnessRequired": "boolean",
    "allowedUses": [
      "string"
    ],
    "limitations": [
      "string"
    ],
    "confidenceImpact": "increase_neutral_decrease_block"
  },
  "guardrails": [
    "Do not allow unknown sources to support final finance conclusions.",
    "Do not allow business press to be the sole source for compliance or program eligibility.",
    "Do not allow stale sources to support current finance claims.",
    "Do not treat user-provided numbers as externally verified facts.",
    "When a source is lower authority than required, downgrade confidence or ask for better evidence."
  ]
}
