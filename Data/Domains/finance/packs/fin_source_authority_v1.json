{
  "id": "fin_source_authority_v1",
  "version": "1.0.0",
  "domain": "finance",
  "layer": "R18D_layer02_source_authority",
  "description": "Authority ranking rules for finance sources. Defines which sources Marion may treat as primary evidence, contextual evidence, user-provided operational inputs, or low-authority signals.",
  "posture": {
    "type": "source_authority_control",
    "educationalOnly": true,
    "decisionSupportOnly": true,
    "notPersonalFinancialAdvice": true,
    "notInvestmentAdvice": true,
    "notLegalOrTaxAdvice": true,
    "sourceTraceRequired": true,
    "freshnessRequiredForCurrentClaims": true,
    "officialSourcesPreferred": true
  },
  "corePrinciples": [
    "Official sources outrank commentary.",
    "Primary regulatory text outranks summaries of regulatory text.",
    "Central banks and official statistics are preferred for macroeconomic claims.",
    "Regulatory filings are preferred for company-specific financial facts.",
    "Business press is useful for narrative context but should not be sole evidence for regulated or current claims.",
    "User-provided business data can support operational analysis but should be labeled as user-supplied and unverified.",
    "Low-authority sources may indicate signals but should not establish final conclusions.",
    "When sources conflict, Marion must downgrade confidence and surface the conflict."
  ],
  "authorityTiers": [
    {
      "tier": "primary_official",
      "label": "Primary Official Source",
      "authorityWeight": 0.95,
      "description": "Government, central bank, regulator, tax authority, official statistics, official program page, or official legislation/regulation source.",
      "allowedUses": [
        "current_policy_claims",
        "regulatory_claims",
        "interest_rate_context",
        "inflation_and_labour_data",
        "official_program_eligibility",
        "tax_or_compliance_context"
      ],
      "examples": [
        "central_bank",
        "official_statistics_agency",
        "securities_regulator",
        "tax_authority",
        "government_program_page",
        "official_legislation_portal"
      ],
      "citationRequired": true
    },
    {
      "tier": "primary_filings",
      "label": "Primary Filing or Disclosure Source",
      "authorityWeight": 0.92,
      "description": "Issuer filings, prospectuses, annual reports, quarterly reports, MD&A, audited financial statements, and official exchange disclosures.",
      "allowedUses": [
        "company_financial_facts",
        "risk_factor_analysis",
        "capital_raise_context",
        "issuer_disclosure",
        "historical_company_metrics"
      ],
      "examples": [
        "SEC EDGAR",
        "SEDAR+",
        "issuer_annual_report",
        "issuer_quarterly_report",
        "audited_financial_statement",
        "prospectus"
      ],
      "citationRequired": true
    },
    {
      "tier": "institutional_multilateral",
      "label": "Institutional or Multilateral Source",
      "authorityWeight": 0.88,
      "description": "IMF, World Bank, OECD, BIS, and comparable institutional sources used for macro, policy, development, and financial stability context.",
      "allowedUses": [
        "global_macro_context",
        "country_context",
        "policy_analysis",
        "financial_stability_context",
        "cross_border_economic_reasoning"
      ],
      "examples": [
        "IMF",
        "World Bank",
        "OECD",
        "BIS"
      ],
      "citationRequired": true
    },
    {
      "tier": "professional_research",
      "label": "Professional Research Source",
      "authorityWeight": 0.8,
      "description": "Professional bodies, accounting firms, financial education institutions, industry research, and specialist publications.",
      "allowedUses": [
        "framework_support",
        "industry_context",
        "methodology_context",
        "capital_markets_concepts",
        "risk_management_concepts"
      ],
      "examples": [
        "CFA Institute",
        "professional_accounting_firm_research",
        "Corporate Finance Institute",
        "industry_association_report"
      ],
      "citationRequired": true
    },
    {
      "tier": "exchange_or_market_reference",
      "label": "Exchange or Market Reference",
      "authorityWeight": 0.78,
      "description": "Exchange pages, market-structure references, index providers, and data reference pages.",
      "allowedUses": [
        "market_structure",
        "listing_context",
        "index_context",
        "instrument_reference",
        "sector_data_context"
      ],
      "examples": [
        "TMX",
        "major_exchange_reference",
        "index_provider",
        "market_data_reference"
      ],
      "citationRequired": true
    },
    {
      "tier": "major_financial_press",
      "label": "Major Financial Press",
      "authorityWeight": 0.68,
      "description": "Major financial and business press used for market narrative, reported developments, and contextual interpretation.",
      "allowedUses": [
        "market_narrative",
        "reported_developments",
        "earnings_context",
        "sector_sentiment",
        "event_context"
      ],
      "examples": [
        "Financial Times",
        "Wall Street Journal",
        "Bloomberg",
        "The Economist",
        "Reuters"
      ],
      "citationRequired": true,
      "limitations": [
        "not_sufficient_alone_for_regulatory_claims",
        "not_sufficient_alone_for_program_eligibility",
        "not_sufficient_alone_for_tax_or_legal_claims",
        "not_sufficient_alone_for_company_filing_facts"
      ]
    },
    {
      "tier": "user_provided_operational_data",
      "label": "User-Provided Operational Data",
      "authorityWeight": 0.72,
      "description": "Numbers, assumptions, business metrics, documents, screenshots, or operational facts provided by the user.",
      "allowedUses": [
        "cashflow_analysis",
        "unit_economics_analysis",
        "scenario_modeling",
        "pricing_modeling",
        "commercial_risk_assessment"
      ],
      "examples": [
        "monthly_burn",
        "cash_on_hand",
        "revenue",
        "CAC",
        "LTV",
        "churn",
        "platform_cost",
        "loan_terms"
      ],
      "citationRequired": false,
      "limitations": [
        "must_be_labeled_user_supplied",
        "not_independently_verified",
        "should_not_be_treated_as_external_fact"
      ]
    },
    {
      "tier": "secondary_context",
      "label": "Secondary Context Source",
      "authorityWeight": 0.52,
      "description": "Blogs, newsletters, explainers, commentary, forums, social posts, and lower-formality sources.",
      "allowedUses": [
        "early_signal_detection",
        "general_context",
        "non_authoritative_explanation",
        "hypothesis_generation"
      ],
      "examples": [
        "blog",
        "newsletter",
        "forum",
        "social_media",
        "commentary_site"
      ],
      "citationRequired": true,
      "limitations": [
        "not_sufficient_for_final_finance_claim",
        "not_sufficient_for_current_regulatory_claim",
        "not_sufficient_for_compliance_answer",
        "must_be_supported_by_higher_authority_source_if_used"
      ]
    },
    {
      "tier": "unsupported_or_unknown",
      "label": "Unsupported or Unknown Source",
      "authorityWeight": 0.2,
      "description": "Unidentified, stale, unsourced, anonymous, promotional, or unverifiable material.",
      "allowedUses": [
        "none_as_primary_evidence"
      ],
      "examples": [
        "unknown_source",
        "unsourced_claim",
        "anonymous_post",
        "promotional_claim",
        "uncited_generated_text"
      ],
      "citationRequired": false,
      "limitations": [
        "cannot_support_final_claim",
        "cannot_support_regulatory_or_market_claim",
        "cannot_support_recommendation"
      ]
    }
  ],
  "sourceTypeRules": {
    "central_bank": {
