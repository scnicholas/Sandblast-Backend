{
  "name": "sandblast-backend",
  "version": "1.0.0",
  "description": "Backend for Sandblast project",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "lint:syntax": "node --check index.js",
    "lint:marion-runtime": "node --check index.js && node --check Data/marion/runtime/marionBridge.js && node --check Data/marion/runtime/composeMarionResponse.js",
    "prestart": "node --check index.js",
    "start": "node index.js",
    "dev": "node --check index.js && node index.js",
    "start:prod": "NODE_ENV=production node --check index.js && NODE_ENV=production node index.js",
    "test": "npx jest",
    "test:lingosentinel": "npx jest tests/lingosentinel --runInBand",
    "test:lingosentinel-node": "node tests/lingosentinel/lingosentinel-core-adapter.test.js && node tests/lingosentinel/lingosentinel-request-envelope.test.js && node tests/lingosentinel/lingosentinel-response-envelope.test.js",
    "test:lingosentinel:node": "node tests/lingosentinel/lingosentinel-core-adapter.test.js && node tests/lingosentinel/lingosentinel-request-envelope.test.js && node tests/lingosentinel/lingosentinel-response-envelope.test.js",
    "test:lingosentinel:all": "npm run test:lingosentinel && npm run test:lingosentinel-node",
    "build:top10": "node Scripts/build_top10_by_year_v1.js",
    "check:top10": "node Scripts/check_top10_by_year_v1.js",
    "top10:rebuild": "npm run build:top10 && npm run check:top10"
  },
  "dependencies": {
    "ably": "^2.22.0",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "form-data": "^4.0.5",
    "gsap": "^3.14.2",
    "multer": "^2.0.2",
    "openai": "^4.104.0",
    "rss-parser": "^3.13.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
